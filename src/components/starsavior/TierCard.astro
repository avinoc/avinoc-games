---
interface Props {
  id?: string;
  tier: string;
  title: string;
  subtitle: string;
  summary: string;
  tags: string[];
  image?: string;
  detail?: string;
  searchText?: string;
  filterValues?: string[];
  buildHref?: string;
  buildLabel?: string;
}

const {
  id,
  tier,
  title,
  subtitle,
  summary,
  tags,
  image,
  detail,
  searchText = `${title} ${subtitle} ${tags.join(" ")}`,
  filterValues = [],
  buildHref,
  buildLabel = "View build"
} = Astro.props;
const base = import.meta.env.BASE_URL;
const resolveAsset = (src?: string) => {
  if (!src) return undefined;
  if (/^https?:\/\//i.test(src)) return src;
  return `${base}${src.replace(/^\/+/, "")}`;
};
const initials = title
  .split(/[\s-]+/)
  .filter(Boolean)
  .slice(0, 2)
  .map((chunk) => chunk[0]?.toUpperCase())
  .join("");
---

<article
  id={id}
  class="content-card tier-card tier-note"
  data-tier={tier}
  data-search={searchText}
  data-focus={filterValues.join(",")}
>
  <div class="tier-card-header">
    <span class:list={["tier-card-avatar", !image && "tier-card-avatar--fallback"]} aria-hidden={image ? "false" : "true"}>
      {image ? (
        <img src={resolveAsset(image)} alt={`${title} artwork`} loading="lazy" />
      ) : (
        <span>{initials}</span>
      )}
    </span>

    <div class="tier-card-copy">
      <div class="card-topline">
        <span class="pill">Tier {tier}</span>
        <span class="muted">{subtitle}</span>
      </div>
      <h3>{title}</h3>
      {detail && <p class="tier-card-detail">{detail}</p>}
    </div>
  </div>

  <p>{summary}</p>
  <div class="tag-row">
    {tags.map((tag) => (
      <span class="tag">{tag}</span>
    ))}
  </div>
  {buildHref && (
    <a class="tier-card-link" href={buildHref}>
      {buildLabel}
    </a>
  )}
</article>

<style>
  .tier-card {
    display: grid;
    gap: 0.9rem;
  }

  .tier-card-header {
    display: flex;
    gap: 0.9rem;
    align-items: flex-start;
  }

  .tier-card-avatar {
    display: grid;
    place-items: center;
    width: 72px;
    height: 72px;
    min-width: 72px;
    overflow: hidden;
    border-radius: 22px;
    border: 1px solid var(--line);
    background: var(--card-media-bg);
    box-shadow: var(--shadow);
  }

  .tier-card-avatar img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 0.45rem;
  }

  .tier-card-avatar--fallback {
    color: var(--ink);
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.04em;
  }

  .tier-card-copy {
    display: grid;
    gap: 0.45rem;
    min-width: 0;
  }

  .card-topline {
    display: flex;
    justify-content: space-between;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .tier-card h3 {
    margin: 0;
  }

  .tier-card-detail {
    margin: 0;
    color: var(--text-soft);
    font-size: 0.92rem;
  }

  .tier-card-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    margin-top: auto;
    padding: 0.72rem 1rem;
    border-radius: 999px;
    border: 1px solid var(--line);
    background: rgba(88, 185, 221, 0.1);
    color: var(--ink);
    font-weight: 600;
    transition: background 160ms ease, transform 160ms ease;
  }

  .tier-card-link:hover {
    background: rgba(88, 185, 221, 0.16);
    transform: translateY(-1px);
  }

  @media (max-width: 540px) {
    .tier-card-avatar {
      width: 60px;
      height: 60px;
      min-width: 60px;
      border-radius: 18px;
    }
  }
</style>
