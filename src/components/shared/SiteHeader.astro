---
import { games } from "../../data/games";

interface Props {
  currentPath: string;
  hideSubnav?: boolean;
}

const { currentPath, hideSubnav = false } = Astro.props;
const base = import.meta.env.BASE_URL;
const normalizePath = (path: string) => (path.endsWith("/") ? path : `${path}/`);
const normalizedCurrentPath = normalizePath(currentPath);

const activeGameSlug = games.find((g) =>
  currentPath.includes(`/${g.slug}/`)
)?.slug;

const activeGame = games.find((g) => g.slug === activeGameSlug);
const navLinks = [
  {
    label: "StarSavior",
    href: `${base}starsavior/`,
    active: activeGameSlug === "starsavior",
  },
  {
    label: "Infinite Lagrange",
    href: `${base}lagrange/`,
    active: activeGameSlug === "lagrange",
  },
  {
    label: "Chaos Zero",
    href: `${base}chaoszero/`,
    active: activeGameSlug === "chaoszero",
  },
  {
    label: "About",
    href: `${base}about/`,
    active: normalizedCurrentPath.startsWith(normalizePath(`${base}about/`)),
  },
  {
    label: "Contact",
    href: `${base}#site-footer`,
    active: false,
  },
];
---

<header class="site-header">
  <div class="container header-row">
    <a class="brand" href={base}>
      <span class="brand-mark">
        <img
          src={`${base}assets/brand/brand-icon.webp`}
          alt=""
          width="44"
          height="44"
        />
      </span>
      <strong>Project Avinoc</strong>
    </a>

    <nav class="primary-nav" aria-label="Primary">
      {navLinks.map((link) => (
        <a
          class:list={["primary-nav__link", { active: link.active }]}
          href={link.href}
          aria-current={link.active ? "page" : undefined}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <div class="header-actions">
      <a class="header-icon-link" href={`${base}search/`} aria-label="Search">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
      </a>
      <button class="theme-toggle" type="button" data-theme-toggle aria-pressed="false" aria-label="Switch to light mode">
        <span class="theme-toggle__track" aria-hidden="true">
          <svg class="theme-toggle__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="4" />
            <path d="M12 2v2.5M12 19.5V22M4.93 4.93l1.77 1.77M17.3 17.3l1.77 1.77M2 12h2.5M19.5 12H22M4.93 19.07l1.77-1.77M17.3 6.7l1.77-1.77" />
          </svg>
          <svg class="theme-toggle__icon" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.95 14.54A9 9 0 0 1 9.46 3.05a1 1 0 0 0-1.18-1.37A10.99 10.99 0 1 0 22.32 15.72a1 1 0 0 0-1.37-1.18Z" />
          </svg>
        </span>
        <span class="sr-only" data-theme-toggle-label>Light mode</span>
      </button>
    </div>
  </div>

  {!hideSubnav && activeGame && (
    <div class="sub-nav-bar">
      <div class="container">
        <nav class="sub-nav" aria-label={`${activeGame.name} navigation`}>
          {activeGame.routes.map((route) => {
            const href = `${base}${route.href.replace(/^\//, "")}`;
            const isActive = currentPath.startsWith(href);
            return (
              <a class:list={["sub-nav-link", { active: isActive }]} href={href}>
                {route.label}
              </a>
            );
          })}
        </nav>
      </div>
    </div>
  )}
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 24;
    backdrop-filter: blur(28px);
    background:
      linear-gradient(180deg, var(--header-bg), rgba(7, 15, 29, 0.76)),
      radial-gradient(circle at top, rgba(76, 144, 255, 0.16), transparent 46%);
    border-bottom: 1px solid rgba(118, 162, 235, 0.14);
    box-shadow: 0 18px 48px rgba(2, 7, 16, 0.22);
  }

  .header-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    min-height: 4.35rem;
    padding: 0.7rem 0 0.65rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    text-decoration: none;
    color: inherit;
    flex-shrink: 0;
  }

  .brand strong {
    color: var(--ink);
    font-family: "Rajdhani", "Space Grotesk", sans-serif;
    font-size: 1.8rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    text-shadow: 0 10px 26px rgba(0, 0, 0, 0.28);
  }

  .brand-mark {
    display: grid;
    place-items: center;
    width: 2.7rem;
    aspect-ratio: 1;
    border-radius: 999px;
    overflow: hidden;
    background: rgba(7, 13, 24, 0.9);
    box-shadow:
      0 0 0 1px rgba(163, 199, 255, 0.18),
      0 12px 24px rgba(2, 7, 16, 0.34);
  }

  .brand-mark img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .primary-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    flex: 1 1 auto;
  }

  .primary-nav__link {
    position: relative;
    display: inline-flex;
    align-items: center;
    min-height: 40px;
    padding: 0.35rem 0;
    border-radius: 0;
    font-size: 1.02rem;
    font-weight: 500;
    color: rgba(229, 239, 255, 0.84);
    text-decoration: none;
    transition: color 160ms ease, opacity 160ms ease;
  }

  .primary-nav__link:hover {
    color: var(--ink);
  }

  .primary-nav__link.active {
    color: var(--ink);
  }

  .primary-nav__link::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -1.05rem;
    height: 0.17rem;
    border-radius: 999px;
    background: linear-gradient(90deg, var(--accent-ice), var(--accent-strong));
    box-shadow:
      0 0 10px var(--accent-glow),
      0 0 22px rgba(71, 184, 255, 0.32);
    opacity: 0;
    transform: scaleX(0.35);
    transition: opacity 160ms ease, transform 160ms ease;
  }

  .primary-nav__link.active::after,
  .primary-nav__link:hover::after {
    opacity: 1;
    transform: scaleX(1);
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.65rem;
  }

  .header-icon-link,
  .theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    border-radius: 999px;
    color: rgba(229, 238, 255, 0.84);
    background: rgba(26, 36, 58, 0.72);
    border: 1px solid rgba(151, 185, 228, 0.12);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.05),
      0 10px 22px rgba(2, 7, 16, 0.24);
    transition: background 160ms ease, color 160ms ease, transform 160ms ease, border-color 160ms ease;
  }

  .header-icon-link {
    width: 44px;
    height: 44px;
  }

  .header-icon-link:hover,
  .theme-toggle:hover {
    background: rgba(35, 50, 79, 0.92);
    color: var(--ink);
    border-color: rgba(120, 186, 255, 0.18);
    transform: translateY(-1px);
  }

  .theme-toggle {
    padding: 0 0.75rem;
    cursor: pointer;
    font: inherit;
  }

  .theme-toggle__track {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
  }

  .theme-toggle__icon {
    padding: 0.22rem;
    border-radius: 999px;
    color: rgba(229, 238, 255, 0.72);
    transition: background 160ms ease, color 160ms ease;
  }

  .theme-toggle[aria-pressed="true"] .theme-toggle__icon:first-child,
  .theme-toggle[aria-pressed="false"] .theme-toggle__icon:last-child {
    color: #ffffff;
    background: rgba(255, 255, 255, 0.12);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .sub-nav-bar {
    border-top: 1px solid rgba(142, 171, 210, 0.08);
    background: rgba(5, 11, 22, 0.44);
  }

  .sub-nav {
    display: flex;
    gap: 0.35rem;
    padding: 0.45rem 0;
    overflow-x: auto;
    scrollbar-width: none;
  }

  .sub-nav::-webkit-scrollbar {
    display: none;
  }

  .sub-nav-link {
    display: inline-flex;
    align-items: center;
    min-height: 40px;
    padding: 0.48rem 0.82rem;
    border-radius: 999px;
    font-size: 0.84rem;
    font-weight: 500;
    color: rgba(214, 228, 248, 0.76);
    text-decoration: none;
    transition: background 160ms ease, color 160ms ease, border-color 160ms ease;
    border: 1px solid transparent;
    white-space: nowrap;
  }

  .sub-nav-link:hover,
  .sub-nav-link.active {
    background: var(--nav-hover-bg);
    color: var(--ink);
    border-color: rgba(104, 167, 255, 0.12);
  }

  :global(html[data-theme="light"]) .site-header {
    background: linear-gradient(180deg, rgba(246, 250, 255, 0.94), rgba(240, 245, 251, 0.78));
    border-bottom-color: rgba(30, 56, 93, 0.1);
    box-shadow: 0 16px 38px rgba(17, 32, 51, 0.08);
  }

  :global(html[data-theme="light"]) .header-icon-link,
  :global(html[data-theme="light"]) .theme-toggle {
    background: rgba(255, 255, 255, 0.8);
    border-color: rgba(28, 57, 95, 0.1);
  }

  :global(html[data-theme="light"]) .primary-nav__link {
    color: rgba(35, 53, 85, 0.82);
  }

  :global(html[data-theme="light"]) .primary-nav__link:hover,
  :global(html[data-theme="light"]) .primary-nav__link.active {
    color: #102037;
  }

  :global(html[data-theme="light"]) .sub-nav-link:hover,
  :global(html[data-theme="light"]) .sub-nav-link.active {
    background: rgba(70, 124, 211, 0.1);
    color: #102037;
  }

  @media (max-width: 780px) {
    .header-row {
      flex-wrap: wrap;
      padding-bottom: 1rem;
    }

    .primary-nav {
      order: 3;
      width: 100%;
      justify-content: flex-start;
      overflow-x: auto;
      scrollbar-width: none;
      padding-bottom: 0.45rem;
    }

    .primary-nav::-webkit-scrollbar {
      display: none;
    }

    .brand strong {
      font-size: 1.45rem;
    }

    .primary-nav__link::after {
      bottom: -0.55rem;
    }
  }
</style>
