---
import { games } from "../../data/games";
import { hubNav } from "../../data/navigation";

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
const base = import.meta.env.BASE_URL;

const activeGameSlug = games.find((g) =>
  currentPath.includes(`/${g.slug}/`)
)?.slug;

const activeGame = games.find((g) => g.slug === activeGameSlug);
---

<header class="site-header">
  <div class="container header-row">
    <a class="brand" href={base}>
      <span class="brand-mark">AG</span>
      <span>
        <strong>Avinoc Games</strong>
        <small>Tools & guides</small>
      </span>
    </a>

    <nav class="game-switcher" aria-label="Game sections">
      {games.filter((g) => g.status === "active").map((game) => (
        <a
          class:list={["game-tab", { active: game.slug === activeGameSlug }]}
          href={`${base}${game.slug}/`}
        >
          {game.name}
        </a>
      ))}
    </nav>

    <div class="header-actions">
      <a class="header-icon-link" href={`${base}search/`} aria-label="Search">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
      </a>
      <button class="theme-toggle" type="button" data-theme-toggle aria-pressed="false" aria-label="Switch to light mode">
        <span class="theme-toggle__swatch" aria-hidden="true"></span>
        <span data-theme-toggle-label>Light mode</span>
      </button>
    </div>
  </div>

  {activeGame && (
    <div class="sub-nav-bar">
      <div class="container">
        <nav class="sub-nav" aria-label={`${activeGame.name} navigation`}>
          {activeGame.routes.map((route) => {
            const href = `${base}${route.href.replace(/^\//, "")}`;
            const isActive = currentPath.startsWith(href);
            return (
              <a class:list={["sub-nav-link", { active: isActive }]} href={href}>
                {route.label}
              </a>
            );
          })}
        </nav>
      </div>
    </div>
  )}
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    backdrop-filter: blur(18px);
    background: var(--header-bg);
    border-bottom: 1px solid var(--line);
  }

  .header-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.8rem 0;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    text-decoration: none;
    color: inherit;
  }

  .brand strong, .brand small { display: block; }
  .brand strong { font-size: 1rem; color: var(--ink); }
  .brand small { color: var(--text-soft); font-size: 0.8rem; }

  .brand-mark {
    display: grid;
    place-items: center;
    width: 2.8rem;
    aspect-ratio: 1;
    border-radius: 18px;
    font-weight: 800;
    letter-spacing: 0.06em;
    color: #1d1202;
    background: linear-gradient(135deg, var(--accent, #f0a03b), #f6d488 70%, var(--accent-ice, #58b9dd));
    box-shadow: 0 10px 24px rgba(61, 149, 185, 0.22);
  }

  .game-switcher {
    display: flex;
    gap: 0.35rem;
  }

  .game-tab {
    display: inline-flex;
    align-items: center;
    padding: 0.55rem 1rem;
    border-radius: 999px;
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--text-soft);
    text-decoration: none;
    transition: background 160ms ease, color 160ms ease;
  }

  .game-tab:hover { background: var(--nav-hover-bg); color: var(--ink); }
  .game-tab.active {
    background: rgba(240, 160, 59, 0.18);
    color: var(--ink);
    border: 1px solid rgba(240, 160, 59, 0.26);
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .header-icon-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 999px;
    color: var(--text-soft);
    transition: background 160ms ease, color 160ms ease;
  }

  .header-icon-link:hover { background: var(--nav-hover-bg); color: var(--ink); }

  .theme-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    min-height: 44px;
    padding: 0.72rem 0.95rem;
    border-radius: 999px;
    border: 1px solid var(--line);
    background: var(--surface-2);
    color: var(--ink);
    font: inherit;
    font-weight: 600;
    cursor: pointer;
    transition: background 160ms ease, transform 160ms ease;
  }

  .theme-toggle:hover { background: var(--nav-hover-bg); transform: translateY(-1px); }

  .theme-toggle__swatch {
    width: 1rem;
    height: 1rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.16);
    background: linear-gradient(135deg, var(--accent, #f0a03b), var(--accent-ice, #58b9dd));
    box-shadow: inset 0 0 0 2px rgba(7, 13, 22, 0.28);
  }

  .sub-nav-bar {
    border-top: 1px solid var(--line);
    background: rgba(7, 13, 22, 0.4);
  }

  .sub-nav {
    display: flex;
    gap: 0.35rem;
    padding: 0.45rem 0;
  }

  .sub-nav-link {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 0.85rem;
    border-radius: 999px;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-soft);
    text-decoration: none;
    transition: background 160ms ease, color 160ms ease;
  }

  .sub-nav-link:hover { background: var(--nav-hover-bg); color: var(--ink); }
  .sub-nav-link.active { background: var(--nav-hover-bg); color: var(--ink); }

  @media (max-width: 780px) {
    .header-row { flex-wrap: wrap; }
    .game-switcher { order: 3; width: 100%; }
    .theme-toggle span[data-theme-toggle-label] { display: none; }
  }
</style>
