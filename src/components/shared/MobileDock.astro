---
interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
const base = import.meta.env.BASE_URL;
const normalizePath = (path: string) => (path.endsWith("/") ? path : `${path}/`);
const normalizedCurrentPath = normalizePath(currentPath);

const items = [
  {
    label: "Home",
    href: base,
    active:
      normalizedCurrentPath === normalizePath(base) ||
      normalizedCurrentPath === normalizePath(`${base}index/`),
    icon: "home",
  },
  {
    label: "Search",
    href: `${base}search/`,
    active: normalizedCurrentPath.startsWith(normalizePath(`${base}search/`)),
    icon: "search",
  },
  {
    label: "Games",
    href: `${base}#game-sections`,
    active:
      normalizedCurrentPath.startsWith(normalizePath(`${base}starsavior/`)) ||
      normalizedCurrentPath.startsWith(normalizePath(`${base}lagrange/`)) ||
      normalizedCurrentPath.startsWith(normalizePath(`${base}chaoszero/`)),
    icon: "games",
  },
  {
    label: "Profile",
    href: `${base}about/#account-roadmap`,
    active: normalizedCurrentPath.startsWith(normalizePath(`${base}about/`)),
    icon: "profile",
  },
];
---

<nav class="mobile-dock" aria-label="Mobile">
  {items.map((item) => (
    <a
      class:list={["mobile-dock__link", { "is-active": item.active }]}
      href={item.href}
      aria-current={item.active ? "page" : undefined}
    >
      <span class="mobile-dock__icon" aria-hidden="true">
        {item.icon === "home" && (
          <svg viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 3.2 2.5 10.8l1.4 1.7L5.5 11v9h5.8v-5.8h1.4V20h5.8v-9l1.6 1.5 1.4-1.7L12 3.2Z" />
          </svg>
        )}
        {item.icon === "search" && (
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="6.5" />
            <path d="m20 20-3.6-3.6" />
          </svg>
        )}
        {item.icon === "games" && (
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M7 10h10a3.5 3.5 0 0 1 3.4 4.2l-.6 2.4A3 3 0 0 1 16.9 19h-1.4a2 2 0 0 1-1.8-1.2l-.4-.8h-2.6l-.4.8A2 2 0 0 1 8.5 19H7.1a3 3 0 0 1-2.9-2.4l-.6-2.4A3.5 3.5 0 0 1 7 10Z" />
            <path d="M8 13v2" />
            <path d="M7 14h2" />
            <circle cx="15.8" cy="13.7" r="0.9" fill="currentColor" stroke="none" />
            <circle cx="18" cy="15.7" r="0.9" fill="currentColor" stroke="none" />
          </svg>
        )}
        {item.icon === "profile" && (
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="8" r="3.5" />
            <path d="M5 19a7 7 0 0 1 14 0" />
          </svg>
        )}
      </span>
      <span>{item.label}</span>
    </a>
  ))}
</nav>

<style>
  .mobile-dock {
    position: fixed;
    inset: auto 0 0;
    z-index: 26;
    display: none;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.4rem;
    padding: 0.6rem 0.75rem calc(0.65rem + env(safe-area-inset-bottom, 0px));
    border-top: 1px solid rgba(118, 161, 223, 0.14);
    background:
      linear-gradient(180deg, rgba(6, 13, 24, 0.82), rgba(5, 11, 21, 0.96)),
      radial-gradient(circle at top, rgba(72, 151, 255, 0.12), transparent 60%);
    backdrop-filter: blur(24px);
    box-shadow: 0 -18px 38px rgba(2, 7, 16, 0.22);
  }

  .mobile-dock__link {
    display: grid;
    justify-items: center;
    gap: 0.32rem;
    min-height: 3.8rem;
    padding: 0.45rem 0.25rem;
    border-radius: 1.15rem;
    color: rgba(208, 222, 244, 0.7);
    font-size: 0.72rem;
    font-weight: 600;
    transition: color 160ms ease, background 160ms ease, transform 160ms ease;
  }

  .mobile-dock__link.is-active {
    color: #ffffff;
    background: rgba(76, 140, 228, 0.16);
    box-shadow: inset 0 0 0 1px rgba(117, 177, 255, 0.14);
  }

  .mobile-dock__link:active {
    transform: translateY(1px);
  }

  .mobile-dock__icon {
    display: grid;
    place-items: center;
    width: 1.55rem;
    height: 1.55rem;
  }

  .mobile-dock__icon svg {
    width: 100%;
    height: 100%;
  }

  @media (max-width: 760px) {
    .mobile-dock {
      display: grid;
    }
  }
</style>
