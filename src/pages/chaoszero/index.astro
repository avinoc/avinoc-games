  .cz-side-card strong,
  .cz-data-row strong,
  .cz-strategy__grid strong {
    color: #f7fbff;
  }

  .cz-dashboard {
    grid-template-columns: minmax(0, 1.05fr) minmax(24rem, 0.95fr);
    padding-bottom: 4rem;
  }

  .cz-panel {
    padding: 1.35rem;
  }

  .cz-panel__header {
    margin-bottom: 1rem;
  }

  .cz-data-table,
  .cz-matrix {
    display: grid;
    gap: 0.65rem;
  }

  .cz-data-table__head,
  .cz-data-row,
  .cz-matrix__head,
  .cz-matrix__row {
    display: grid;
    grid-template-columns: minmax(0, 1.5fr) repeat(3, minmax(0, 0.5fr));
    gap: 0.8rem;
