  }

  .cz-side-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 26px 54px rgba(0, 0, 0, 0.42);
  }

  .cz-side-card--static:hover {
    transform: none;
  }

  .cz-fso-banner {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.85rem 1.2rem;
    border-radius: 1rem;
    background: linear-gradient(135deg, rgba(168, 85, 247, 0.1), rgba(192, 132, 252, 0.06));
    border: 1px solid rgba(168, 85, 247, 0.25);
    text-decoration: none;
    color: inherit;
    margin-bottom: 1.5rem;
    transition: border-color 200ms ease, box-shadow 200ms ease;
    flex-wrap: wrap;
  }

  .cz-fso-banner:hover {
    border-color: rgba(168, 85, 247, 0.4);
    box-shadow: 0 0 0 1px rgba(168, 85, 247, 0.15);
  }

  .cz-fso-banner__tag {
    display: inline-flex;
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    background: rgba(168, 85, 247, 0.15);
    border: 1px solid rgba(168, 85, 247, 0.3);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--accent);
    font-weight: 600;
    white-space: nowrap;
  }

  .cz-fso-banner strong {
    font-size: 0.95rem;
    font-weight: 700;
    color: #f7fbff;
  }

  .cz-fso-banner span {
    font-size: 0.82rem;
    color: rgba(211, 226, 244, 0.7);
  }

  .cz-fso-banner svg {
    color: var(--accent);
    flex-shrink: 0;
    margin-left: auto;
  }

  @media (max-width: 768px) {
    .cz-fso-banner {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.4rem;
    }

    .cz-fso-banner svg {
      margin-left: 0;
    }
