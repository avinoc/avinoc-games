  .cz-bar__fill {
    height: 100%;
    border-radius: inherit;
    background: linear-gradient(90deg, rgba(217, 70, 168, 0.96), rgba(34, 211, 238, 0.86));
  }

  .cz-matrix__head,
  .cz-matrix__row {
    grid-template-columns: minmax(0, 1.35fr) repeat(5, minmax(0, 0.58fr));
  }

  .cz-matrix__head span,
  .cz-matrix__row span {
    font-size: 0.8rem;
  }

  .cz-strategy__grid {
    display: grid;
    gap: 0.85rem;
  }

  .cz-strategy__grid article {
    padding: 0.95rem 1rem;
    border-radius: 1rem;
    background: rgba(10, 19, 35, 0.86);
    border: 1px solid rgba(127, 169, 224, 0.12);
  }

  @media (max-width: 1120px) {
    .cz-hero-grid,
    .cz-dashboard,
    .cz-feature-card {
      grid-template-columns: 1fr;
    }

    .cz-sidebar {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
