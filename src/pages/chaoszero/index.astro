  .cz-bar-stack {
    display: grid;
    gap: 0.8rem;
  }

  .cz-bar {
    display: grid;
    gap: 0.45rem;
  }

  .cz-bar__head {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
  }

  .cz-bar__head strong {
    color: #f7fbff;
    font-size: 0.86rem;
  }

  .cz-bar__track {
    height: 0.72rem;
    overflow: hidden;
    border-radius: 999px;
    background: rgba(11, 20, 35, 0.96);
