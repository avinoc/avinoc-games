---
import GameLayout from "../../layouts/GameLayout.astro";
const base = import.meta.env.BASE_URL;
---

<GameLayout
  title="Infinite Lagrange"
  description="Fleet composition planner for Infinite Lagrange."
  game="lagrange"
>
  <section class="hero">
    <div class="container">
      <div class="hero-wrap" style="--accent: #22d3ee; --accent-ice: #3b82f6;">
        <p class="eyebrow">Infinite Lagrange</p>
        <h1>Plan your fleet before you deploy.</h1>
        <p>
          Build and share fleet compositions with a database of 145+ ships across 8 classes.
          Track CP totals, save multiple fleets, and share them with a link.
        </p>
        <div class="hero-actions">
          <a class="button primary" href={`${base}lagrange/fleet-builder`}>Open Fleet Builder</a>
        </div>
      </div>
    </div>
  </section>

  <section class="container stack">
    <div class="panel" style="padding: 1.4rem;">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Features</p>
          <h2>What the fleet builder does</h2>
        </div>
      </div>

      <div class="card-grid">
        <article class="content-card">
          <h3>Ship Database</h3>
          <p>145+ ships across Fighters, Corvettes, Frigates, Destroyers, Cruisers, Battlecruisers, Carriers, and Battleships.</p>
        </article>
        <article class="content-card">
          <h3>CP Tracking</h3>
          <p>Real-time combat power calculation with configurable max CP limits. Add reinforced variants at 0 CP.</p>
        </article>
        <article class="content-card">
          <h3>Save & Share</h3>
          <p>Save multiple fleet configurations locally and generate shareable links backed by Supabase.</p>
        </article>
      </div>
    </div>
  </section>
</GameLayout>
