---
import GameLayout from "../../layouts/GameLayout.astro";

const base = import.meta.env.BASE_URL;
const heroArt = `${base}assets/home/lagrange-hero.jpg`;

const commandStats = [
  { value: "400", label: "Default CP cap" },
  { value: "8", label: "Ship classes indexed" },
  { value: "Live", label: "Save + share support" },
];

const capabilityCards = [
  {
    title: "Composition Grid",
    summary: "Assemble fleets by class, stack reinforcements, and keep the active roster visible while you plan.",
    accent: "cyan",
  },
  {
    title: "Command Budget",
    summary: "Track total CP in real time so budget pressure is obvious before you overbuild a lane.",
    accent: "steel",
  },
  {
    title: "Fleet Archive",
    summary: "Save local fleet drafts, reload them later, and publish share links when a lineup is ready.",
    accent: "ghost",
  },
];

const commandModules = [
  { label: "Planner", detail: "Interactive React island", state: "Live" },
  { label: "Saved Fleets", detail: "Local archive drawer", state: "Live" },
  { label: "Share Links", detail: "Supabase-backed fleet URLs", state: "Live" },
];
---

<GameLayout
  title="Infinite Lagrange Dashboard"
  description="Command-bridge landing page for the Infinite Lagrange fleet planner."
  game="lagrange"
  hideSubnav={true}
>
  <section class="lagrange-shell">
    <div
      class="lagrange-shell__art"
      style={`background-image:
        linear-gradient(180deg, rgba(4, 10, 18, 0.24), rgba(5, 10, 18, 0.86)),
        radial-gradient(circle at 76% 10%, rgba(96, 175, 217, 0.14), transparent 26%),
        url('${heroArt}')`}
      aria-hidden="true"
    ></div>
    <div class="lagrange-shell__stars" aria-hidden="true"></div>
    <div class="lagrange-shell__ring" aria-hidden="true"></div>

    <div class="container lagrange-layout">
      <header class="lagrange-hero">
        <p class="lagrange-hero__eyebrow">Infinite Lagrange Command Deck</p>
        <h1>Plan the fleet you can actually deploy.</h1>
        <p class="lagrange-hero__summary">
          The public Lagrange section is intentionally scoped to the live Fleet Planner. Dead placeholder tools are removed until they have real backing pages and data.
        </p>

        <div class="lagrange-hero__actions">
          <a class="lagrange-button" href={`${base}lagrange/fleet-builder`}>
            Open Fleet Planner
            <span aria-hidden="true">→</span>
          </a>
        </div>

        <ul class="lagrange-stat-row" role="list">
          {commandStats.map((stat) => (
            <li>
              <strong>{stat.value}</strong>
              <span>{stat.label}</span>
            </li>
          ))}
        </ul>
      </header>

      <div class="lagrange-dashboard">
        <article class="bridge-panel bridge-panel--planner">
          <div class="bridge-panel__copy">
            <p class="bridge-panel__label">Fleet Planner</p>
            <h2>Live command module</h2>
            <p>
              Build fleets from the ship registry, watch CP totals update in real time, and move from shortlist to shareable composition without leaving the planner.
            </p>

            <div class="bridge-panel__modules">
              {commandModules.map((module) => (
                <div class="module-chip">
                  <div>
                    <strong>{module.label}</strong>
                    <span>{module.detail}</span>
                  </div>
                  <em>{module.state}</em>
                </div>
              ))}
            </div>
          </div>

          <div class="bridge-preview" aria-hidden="true">
            <div class="bridge-preview__header">
              <span class="is-active">Fleet Planner</span>
              <span>Deploy Slots</span>
              <span>Archive</span>
            </div>

            <div class="bridge-preview__grid">
              <div class="bridge-preview__column">
                <p>Frigates</p>
                <span class="ship-mark ship-mark--md"></span>
                <span class="ship-mark ship-mark--lg"></span>
                <span class="ship-mark ship-mark--sm"></span>
              </div>

              <div class="bridge-preview__column bridge-preview__column--center">
                <p>Active Fleet</p>
                <div class="fleet-row">
                  <span class="ship-mark ship-mark--carrier"></span>
                </div>
                <div class="fleet-row fleet-row--split">
                  <span class="ship-mark ship-mark--lg"></span>
                  <span class="ship-mark ship-mark--md"></span>
                </div>
                <div class="fleet-row fleet-row--split">
                  <span class="ship-mark ship-mark--md"></span>
                  <span class="ship-mark ship-mark--sm"></span>
                </div>
              </div>

              <div class="bridge-preview__column">
                <p>Statistics</p>
                <div class="stat-meter">
                  <small>CP</small>
                  <strong>286 / 400</strong>
                </div>
                <div class="stat-meter">
                  <small>Frontline</small>
                  <strong>8 hulls</strong>
                </div>
                <div class="stat-meter">
                  <small>Support</small>
                  <strong>3 carriers</strong>
                </div>
              </div>
            </div>
          </div>
        </article>

        <aside class="bridge-rail">
          {capabilityCards.map((card) => (
            <article class:list={["bridge-rail__card", `bridge-rail__card--${card.accent}`]}>
              <span class="bridge-rail__state">Online</span>
              <h2>{card.title}</h2>
              <p>{card.summary}</p>
            </article>
          ))}
        </aside>
      </div>
    </div>
  </section>
</GameLayout>

<style>
  .lagrange-shell {
    position: relative;
    min-height: calc(100vh - 4.35rem);
    overflow: clip;
    padding: clamp(2.1rem, 4vw, 3.4rem) 0 4.5rem;
    isolation: isolate;
    background:
      radial-gradient(circle at 18% 12%, rgba(62, 123, 163, 0.18), transparent 22%),
      radial-gradient(circle at 86% 10%, rgba(101, 174, 212, 0.12), transparent 24%),
      linear-gradient(180deg, #050b13 0%, #070d16 56%, #050911 100%);
  }

  .lagrange-shell__art,
  .lagrange-shell__stars,
  .lagrange-shell__ring {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .lagrange-shell__art {
    inset: 0 0 auto;
    z-index: -3;
    height: min(42rem, 68vw);
    background-position: center top;
    background-repeat: no-repeat;
    background-size: cover;
    opacity: 0.38;
    mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.98), transparent 92%);
  }

  .lagrange-shell__stars {
    z-index: -2;
    opacity: 0.62;
    background:
      radial-gradient(circle at 11% 22%, rgba(255, 255, 255, 0.54) 0 1px, transparent 1.8px),
      radial-gradient(circle at 29% 10%, rgba(150, 202, 230, 0.48) 0 1.1px, transparent 1.9px),
      radial-gradient(circle at 54% 18%, rgba(255, 255, 255, 0.42) 0 1px, transparent 1.8px),
      radial-gradient(circle at 76% 12%, rgba(129, 192, 228, 0.42) 0 1.1px, transparent 1.8px),
      radial-gradient(circle at 88% 26%, rgba(255, 255, 255, 0.36) 0 1px, transparent 1.8px);
  }

  .lagrange-shell__ring {
    z-index: -1;
    inset: auto -12rem 12rem auto;
    width: 32rem;
    height: 32rem;
    border-radius: 999px;
    border: 1px solid rgba(100, 160, 193, 0.14);
    box-shadow:
      inset 0 0 0 1px rgba(155, 198, 222, 0.04),
      0 0 6rem rgba(65, 109, 148, 0.14);
    transform: rotate(-18deg);
  }

  .lagrange-layout {
    position: relative;
    z-index: 1;
  }

  .lagrange-hero {
    display: grid;
    gap: 1rem;
    margin-bottom: 1.4rem;
    max-width: 48rem;
  }

  .lagrange-hero__eyebrow,
  .bridge-panel__label,
  .bridge-rail__state,
  .bridge-preview__column p,
  .stat-meter small {
    margin: 0;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(173, 199, 216, 0.64);
  }

  .lagrange-hero h1,
  .bridge-panel h2,
  .bridge-rail__card h2 {
    margin: 0;
    font-family: "Rajdhani", "Space Grotesk", sans-serif;
    line-height: 0.98;
    letter-spacing: -0.04em;
  }

  .lagrange-hero h1 {
    font-size: clamp(3rem, 6vw, 4.85rem);
    color: #ecf6ff;
    text-shadow:
      0 0 18px rgba(89, 163, 210, 0.16),
      0 18px 42px rgba(0, 0, 0, 0.42);
  }

  .lagrange-hero__summary,
  .bridge-panel__copy > p:last-of-type,
  .bridge-rail__card p {
    margin: 0;
    color: rgba(176, 196, 212, 0.78);
    line-height: 1.7;
  }

  .lagrange-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
  }

  .lagrange-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
    min-height: 3rem;
    padding: 0.85rem 1.2rem;
    border-radius: 999px;
    border: 1px solid rgba(113, 170, 202, 0.32);
    background: linear-gradient(135deg, rgba(35, 75, 111, 0.96), rgba(70, 136, 177, 0.92));
    color: #f5fbff;
    font-weight: 700;
    box-shadow: 0 16px 32px rgba(17, 40, 63, 0.24);
  }

  .lagrange-stat-row {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.9rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .lagrange-stat-row li,
  .bridge-panel,
  .bridge-rail__card {
    border-radius: 1.4rem;
    border: 1px solid rgba(89, 137, 168, 0.2);
    background: rgba(10, 19, 31, 0.9);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.04),
      0 24px 60px rgba(0, 0, 0, 0.28);
    backdrop-filter: blur(16px);
  }

  .lagrange-stat-row li {
    padding: 1rem 1.05rem;
  }

  .lagrange-stat-row strong {
    display: block;
    color: #f5fbff;
    font-size: 1.45rem;
    font-weight: 700;
  }

  .lagrange-stat-row span {
    display: block;
    margin-top: 0.2rem;
    color: rgba(166, 188, 205, 0.72);
    font-size: 0.9rem;
  }

  .lagrange-dashboard {
    display: grid;
    grid-template-columns: minmax(0, 1.12fr) 20rem;
    gap: 1rem;
    align-items: start;
  }

  .bridge-panel {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(18rem, 1.1fr);
    gap: 1rem;
    padding: 1.25rem;
  }

  .bridge-panel__copy {
    display: grid;
    align-content: start;
    gap: 0.9rem;
  }

  .bridge-panel h2 {
    font-size: clamp(2rem, 3.4vw, 3rem);
    color: #f2f9ff;
  }

  .bridge-panel__modules {
    display: grid;
    gap: 0.75rem;
    margin-top: 0.25rem;
  }

  .module-chip {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: start;
    padding: 0.9rem 1rem;
    border-radius: 1rem;
    border: 1px solid rgba(97, 144, 176, 0.18);
    background: rgba(13, 26, 42, 0.9);
  }

  .module-chip strong,
  .stat-meter strong {
    display: block;
    color: #f4fbff;
    font-size: 1rem;
  }

  .module-chip span {
    display: block;
    margin-top: 0.2rem;
    color: rgba(167, 189, 205, 0.72);
    font-size: 0.88rem;
    line-height: 1.5;
  }

  .module-chip em {
    font-style: normal;
    color: #8cc5e0;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .bridge-preview {
    overflow: hidden;
    border-radius: 1.1rem;
    border: 1px solid rgba(88, 135, 165, 0.18);
    background:
      linear-gradient(180deg, rgba(10, 21, 36, 0.98), rgba(7, 14, 26, 0.98)),
      radial-gradient(circle at 78% 20%, rgba(95, 174, 217, 0.16), transparent 28%);
  }

  .bridge-preview__header {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    padding: 0.9rem 0.95rem 0;
  }

  .bridge-preview__header span {
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    border: 1px solid rgba(101, 152, 185, 0.16);
    background: rgba(20, 35, 56, 0.76);
    color: rgba(210, 228, 239, 0.78);
    font-size: 0.8rem;
  }

  .bridge-preview__header .is-active {
    background: rgba(51, 103, 142, 0.76);
    color: #f5fbff;
  }

  .bridge-preview__grid {
    display: grid;
    grid-template-columns: 11rem minmax(0, 1fr) 10rem;
    gap: 0.9rem;
    padding: 1rem 0.95rem 0.95rem;
  }

  .bridge-preview__column {
    display: grid;
    align-content: start;
    gap: 0.7rem;
    padding: 0.9rem;
    border-radius: 1rem;
    background: rgba(12, 25, 40, 0.88);
    border: 1px solid rgba(93, 142, 173, 0.14);
  }

  .bridge-preview__column--center {
    background:
      linear-gradient(180deg, rgba(10, 23, 38, 0.96), rgba(8, 17, 31, 0.96));
  }

  .fleet-row {
    display: flex;
    min-height: 1.35rem;
  }

  .fleet-row--split {
    justify-content: space-between;
    gap: 0.8rem;
  }

  .ship-mark {
    display: inline-flex;
    height: 0.82rem;
    border-radius: 999px;
    background: linear-gradient(90deg, rgba(239, 246, 255, 0.92), rgba(132, 190, 220, 0.82));
    clip-path: polygon(0 48%, 12% 30%, 44% 24%, 68% 0, 100% 38%, 84% 58%, 92% 78%, 60% 74%, 28% 100%, 12% 72%);
    filter: drop-shadow(0 0 6px rgba(96, 173, 210, 0.3));
  }

  .ship-mark--sm { width: 2.5rem; }
  .ship-mark--md { width: 4rem; }
  .ship-mark--lg { width: 5.4rem; }
  .ship-mark--carrier { width: 7.2rem; height: 0.92rem; }

  .stat-meter {
    display: grid;
    gap: 0.2rem;
    padding: 0.8rem 0.85rem;
    border-radius: 0.9rem;
    background: rgba(16, 31, 48, 0.84);
    border: 1px solid rgba(92, 138, 165, 0.14);
  }

  .bridge-rail {
    display: grid;
    gap: 0.85rem;
  }

  .bridge-rail__card {
    display: grid;
    gap: 0.75rem;
    padding: 1rem;
  }

  .bridge-rail__card h2 {
    font-size: 1.55rem;
    color: #f2f9ff;
  }

  .bridge-rail__card--cyan {
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.04),
      0 24px 60px rgba(0, 0, 0, 0.28),
      0 0 0 1px rgba(104, 173, 211, 0.08);
  }

  .bridge-rail__card--steel {
    border-color: rgba(111, 136, 155, 0.2);
  }

  .bridge-rail__card--ghost {
    border-color: rgba(133, 167, 189, 0.14);
    background: rgba(10, 17, 27, 0.9);
  }

  :global(html[data-theme="light"]) .lagrange-shell {
    background:
      radial-gradient(circle at 18% 12%, rgba(78, 137, 173, 0.1), transparent 22%),
      radial-gradient(circle at 86% 10%, rgba(101, 174, 212, 0.08), transparent 24%),
      linear-gradient(180deg, #e8f0f7 0%, #dde6ef 56%, #d7e0eb 100%);
  }

  :global(html[data-theme="light"]) .lagrange-shell__art {
    opacity: 0.2;
  }

  :global(html[data-theme="light"]) .lagrange-hero h1 {
    color: #173049;
    text-shadow: none;
  }

  :global(html[data-theme="light"]) .lagrange-hero__summary,
  :global(html[data-theme="light"]) .bridge-panel__copy > p:last-of-type,
  :global(html[data-theme="light"]) .bridge-rail__card p,
  :global(html[data-theme="light"]) .module-chip span {
    color: rgba(45, 68, 88, 0.82);
  }

  @media (max-width: 1120px) {
    .lagrange-dashboard {
      grid-template-columns: 1fr;
    }

    .bridge-rail {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 900px) {
    .bridge-panel {
      grid-template-columns: 1fr;
    }

    .bridge-preview__grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 720px) {
    .lagrange-shell {
      padding-top: 1.6rem;
    }

    .lagrange-stat-row,
    .bridge-rail {
      grid-template-columns: 1fr;
    }

    .lagrange-hero h1 {
      font-size: 2.7rem;
    }
  }

  @media (max-width: 560px) {
    .bridge-panel,
    .bridge-rail__card,
    .lagrange-stat-row li {
      padding-left: 0.95rem;
      padding-right: 0.95rem;
    }

    .module-chip {
      grid-template-columns: 1fr;
    }
  }
</style>
