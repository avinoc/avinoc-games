---
import HubLayout from "../layouts/HubLayout.astro";

const base = import.meta.env.BASE_URL;
const withBase = (path: string) => `${base}${path.replace(/^\//, "")}`;

const brandPanel = withBase("/assets/home/project-avinoc-brand-panel.png");
const heroPanels = {
  starsavior: withBase("/assets/home/starsavior-hero.jpg"),
  lagrange: withBase("/assets/home/lagrange-hero.jpg"),
  chaoszero: withBase("/assets/chaoszero/hero-story.webp"),
};

const sectionCards = [
  {
    name: "Star Savior",
    href: `${base}starsavior/`,
    description: "Builds, tier lists, and progression guides sourced from Bullet's strategy sheet.",
    image: withBase("/assets/home/starsavior-card.jpg"),
    theme: "violet",
  },
  {
    name: "Infinite Lagrange",
    href: `${base}lagrange/`,
    description: "Fleet composition planner with CP tracking and fleet sharing.",
    image: withBase("/assets/home/lagrange-card.jpg"),
    theme: "cyan",
  },
  {
    name: "Chaos Zero",
    href: `${base}chaoszero/`,
    description: "Great Rift build packs, screenshot lineups, and event score breakdowns.",
    image: heroPanels.chaoszero,
    theme: "chaos",
  },
  {
    name: "Epic Seven",
    href: `${base}epicseven/`,
    description: "Tools, guides, and database information for Epic Seven — new Ancient Inheritance guide available.",
    image: "",
    theme: "orange",
  },
];
---

<HubLayout
  title="Project Avinoc | Tools & Guides"
  description="Tools, guides, and resources for the games I play."
>
  <div class="landing-shell">
    <div
      class="landing-shell__brand-veil"
      style={`background-image: url('${brandPanel}')`}
      aria-hidden="true"
    ></div>

    <section class="landing-hero">
      <div class="landing-hero__frame">
        <div class="landing-hero__art" aria-hidden="true">
          <div
            class="landing-hero__panel landing-hero__panel--starsavior"
            style={`background-image: linear-gradient(180deg, rgba(8, 17, 36, 0.14), rgba(5, 12, 24, 0.28)), url('${heroPanels.starsavior}')`}
          ></div>
          <div
            class="landing-hero__panel landing-hero__panel--lagrange"
            style={`background-image: linear-gradient(180deg, rgba(6, 12, 28, 0.12), rgba(2, 6, 18, 0.4)), url('${heroPanels.lagrange}')`}
          ></div>
          <div
            class="landing-hero__panel landing-hero__panel--chaos"
            style={`background-image: linear-gradient(180deg, rgba(24, 4, 22, 0.08), rgba(8, 2, 18, 0.44)), url('${heroPanels.chaoszero}')`}
          ></div>
          <div class="landing-hero__beam"></div>
          <div class="landing-hero__shade"></div>
        </div>

        <div class="landing-hero__content">
          <h1>Project Avinoc</h1>
          <p class="landing-hero__tagline">Tools, guides, and resources for the games I play.</p>

          <form class="landing-search" action={`${base}search/`} method="get" role="search">
            <label class="sr-only" for="home-search">Search guides, tools, and more</label>
            <input
              id="home-search"
              type="search"
              name="q"
              placeholder="Search guides, tools, and more..."
              autocomplete="off"
            />
            <button type="submit" aria-label="Search the site">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="7" />
                <path d="m20 20-3.5-3.5" />
              </svg>
            </button>
          </form>
        </div>
      </div>
    </section>

    <section class="landing-sections" id="game-sections">
      <div class="container landing-sections__inner">
        <p class="landing-sections__eyebrow"><span>GAME SECTIONS</span> - Pick a game to explore</p>

        <div class="landing-cards">
          {sectionCards.map((card) => (
            <a
              class:list={[
                "feature-card",
                `feature-card--${card.theme}`,
                card.comingSoon && "feature-card--coming-soon"
              ]}
              href={card.href}
            >
              {card.image && (
                <div
                  class="feature-card__media"
                  style={`background-image: linear-gradient(180deg, rgba(255, 255, 255, 0.02), rgba(3, 8, 18, 0.18)), url('${card.image}')`}
                  aria-hidden="true"
                ></div>
              )}
              <div class="feature-card__haze" aria-hidden="true"></div>
              <div class="feature-card__veil" aria-hidden="true"></div>

              <div class="feature-card__content">
                {card.comingSoon
                  ? <span class="feature-card__status feature-card__status--coming-soon">Coming Soon</span>
                  : <span class="feature-card__status">Active</span>
                }
                <h2>{card.name}</h2>
                <p>{card.description}</p>
                <span class="feature-card__button">
                  {card.comingSoon ? "Stay Tuned" : "Explore"}
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 8h10" />
                    <path d="m9 4 4 4-4 4" />
                  </svg>
                </span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  </div>
</HubLayout>

<style>
  .landing-shell {
    position: relative;
    padding-bottom: 1.5rem;
    isolation: isolate;
  }

  .landing-shell::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -2;
    pointer-events: none;
    background:
      radial-gradient(circle at 16% 18%, rgba(184, 108, 255, 0.16), transparent 24%),
      radial-gradient(circle at 84% 18%, rgba(68, 155, 255, 0.22), transparent 30%),
      linear-gradient(180deg, rgba(7, 13, 22, 0) 0%, rgba(4, 9, 18, 0.78) 48%, rgba(3, 7, 16, 0.92) 100%);
  }

  .landing-shell__brand-veil {
    position: absolute;
    inset: 8rem 0 auto;
    height: min(62vw, 38rem);
    z-index: -1;
    background-repeat: no-repeat;
    background-position: center top;
    background-size: min(96vw, 82rem);
    opacity: 0.16;
    filter: blur(18px) saturate(0.9);
    pointer-events: none;
    mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.8), transparent 100%);
  }

  .landing-hero {
    position: relative;
    padding-top: 0.35rem;
  }

  .landing-hero__frame {
    position: relative;
    min-height: 40rem;
    background: #07101d;
  }

  .landing-hero__art,
  .landing-hero__shade {
    position: absolute;
    inset: 0;
  }

  .landing-hero__panel {
    position: absolute;
    top: 0;
    bottom: 0;
    background-position: center;
    background-size: cover;
    background-repeat: no-repeat;
  }

  .landing-hero__panel--starsavior {
    left: 0;
    width: 58%;
    clip-path: polygon(0 0, 100% 0, 82% 100%, 0 100%);
  }

  .landing-hero__panel--lagrange {
    right: 0;
    width: 54%;
    clip-path: polygon(18% 0, 100% 0, 100% 100%, 0 100%);
    background-position: right center;
  }

  .landing-hero__panel--chaos {
    inset: auto 0 0 auto;
    width: 38%;
    height: 46%;
    clip-path: polygon(24% 0, 100% 0, 100% 100%, 0 100%);
    background-position: center top;
    opacity: 0.6;
    mix-blend-mode: screen;
  }

  .landing-hero__beam {
    position: absolute;
    top: -14%;
    bottom: -14%;
    left: 50%;
    width: 16%;
    transform: translateX(-50%) rotate(10deg);
    background:
      linear-gradient(90deg, rgba(84, 192, 255, 0) 0%, rgba(100, 210, 255, 0.65) 48%, rgba(84, 192, 255, 0) 100%);
    filter: blur(16px);
    opacity: 0.95;
  }

  .landing-hero__beam::before {
    content: "";
    position: absolute;
    inset: 0 42%;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.88), rgba(92, 195, 255, 0.75));
    box-shadow:
      0 0 18px rgba(108, 206, 255, 0.95),
      0 0 42px rgba(68, 155, 255, 0.72);
  }

  .landing-hero__shade {
    background:
      linear-gradient(180deg, rgba(3, 8, 16, 0.28) 0%, rgba(6, 12, 24, 0.12) 30%, rgba(5, 11, 22, 0.62) 100%),
      radial-gradient(circle at center, rgba(14, 22, 41, 0) 18%, rgba(4, 8, 18, 0.56) 100%);
  }

  .landing-hero__content {
    position: relative;
    z-index: 2;
    display: grid;
    justify-items: center;
    text-align: center;
    width: min(var(--content), calc(100% - 2.5rem));
    margin: 0 auto;
    padding: 7.4rem 1.5rem 11rem;
  }

  .landing-hero__content h1 {
    margin: 0;
    font-family: "Space Grotesk", "Segoe UI", sans-serif;
    font-size: clamp(3.35rem, 7vw, 5.4rem);
    line-height: 0.94;
    font-weight: 700;
    letter-spacing: -0.05em;
    color: #f8fbff;
    text-shadow: 0 16px 42px rgba(0, 0, 0, 0.45);
  }

  .landing-hero__tagline {
    margin: 1rem 0 0;
    max-width: 48rem;
    font-size: clamp(1.1rem, 2vw, 1.65rem);
    color: rgba(241, 247, 255, 0.92);
    text-shadow: 0 10px 20px rgba(0, 0, 0, 0.3);
  }

  .landing-search {
    width: min(100%, 35.5rem);
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 0.5rem;
    align-items: center;
    margin-top: 2rem;
    padding: 0.45rem 0.6rem 0.45rem 1.5rem;
    border-radius: 999px;
    background: rgba(13, 23, 41, 0.18);
    border: 1px solid rgba(227, 238, 255, 0.2);
    box-shadow:
      0 22px 45px rgba(2, 7, 16, 0.35),
      inset 0 1px 0 rgba(255, 255, 255, 0.16);
    backdrop-filter: blur(22px);
  }

  .landing-search input {
    width: 100%;
    border: 0;
    outline: 0;
    background: transparent;
    color: #f6fbff;
    font: inherit;
    font-size: 1.08rem;
  }

  .landing-search input::placeholder {
    color: rgba(215, 228, 244, 0.58);
  }

  .landing-search button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    border: 0;
    border-radius: 999px;
    background: transparent;
    color: rgba(234, 243, 255, 0.9);
    cursor: pointer;
    transition: background 160ms ease, color 160ms ease, transform 160ms ease;
  }

  .landing-search button:hover {
    background: rgba(255, 255, 255, 0.08);
    color: #ffffff;
    transform: translateY(-1px);
  }

  .landing-sections {
    position: relative;
    z-index: 2;
    margin-top: -6.6rem;
  }

  .landing-sections__inner {
    position: relative;
  }

  .landing-sections__eyebrow {
    margin: 0 0 1.35rem;
    color: rgba(239, 245, 255, 0.8);
    font-family: "Rajdhani", "Space Grotesk", sans-serif;
    font-size: 1.2rem;
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  .landing-sections__eyebrow span {
    font-weight: 700;
    color: #ffffff;
  }

  .landing-cards {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.2rem;
  }

  .feature-card {
    --button-start: #8847ff;
    --button-end: #d95dff;
    --status-bg: rgba(31, 196, 124, 0.18);
    --status-border: rgba(76, 229, 150, 0.22);
    --status-text: #85f2b7;
    --border-color: rgba(168, 136, 255, 0.26);
    --card-glow: rgba(217, 93, 255, 0.28);
    --card-shadow: rgba(217, 93, 255, 0.12);
    position: relative;
    display: flex;
    align-items: flex-end;
    min-height: 17rem;
    overflow: hidden;
    border-radius: 1.65rem;
    border: 1px solid var(--border-color);
    text-decoration: none;
    color: #ffffff;
    box-shadow:
      0 24px 50px rgba(2, 7, 16, 0.32),
      inset 0 1px 0 rgba(255, 255, 255, 0.08);
    transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
  }

  .feature-card:hover {
    transform: translateY(-5px);
    border-color: rgba(183, 211, 255, 0.34);
    box-shadow:
      0 28px 65px rgba(2, 7, 16, 0.46),
      0 0 0 1px rgba(183, 211, 255, 0.06);
  }

  .feature-card--cyan {
    --button-start: #1681ff;
    --button-end: #32bbff;
    --border-color: rgba(82, 167, 255, 0.26);
    --card-glow: rgba(80, 181, 255, 0.2);
    --card-shadow: rgba(50, 187, 255, 0.1);
  }

  .feature-card--chaos {
    --button-start: #cf3d96;
    --button-end: #ff6c43;
    --status-bg: rgba(255, 102, 170, 0.14);
    --status-border: rgba(255, 123, 197, 0.22);
    --status-text: #ff9ed5;
    --border-color: rgba(224, 92, 166, 0.28);
    --card-glow: rgba(232, 65, 144, 0.24);
    --card-shadow: rgba(255, 108, 67, 0.12);
  }

  .feature-card--orange {
    --button-start: #f97316;
    --button-end: #ea580c;
    --status-bg: rgba(249, 115, 22, 0.14);
    --status-border: rgba(251, 146, 60, 0.22);
    --status-text: #fdba74;
    --border-color: rgba(249, 115, 22, 0.28);
    --card-glow: rgba(249, 115, 22, 0.2);
    --card-shadow: rgba(234, 88, 12, 0.1);
  }

  .feature-card--coming-soon {
    opacity: 0.75;
  }

  .feature-card__status--coming-soon {
    --status-bg: rgba(249, 115, 22, 0.14);
    --status-border: rgba(251, 146, 60, 0.22);
    --status-text: #fdba74;
  }

  .feature-card__media,
  .feature-card__haze,
  .feature-card__veil {
    position: absolute;
    inset: 0;
  }

  .feature-card__media {
    background-position: center;
    background-size: cover;
    background-repeat: no-repeat;
    transition: transform 220ms ease;
  }

  .feature-card:hover .feature-card__media {
    transform: scale(1.03);
  }

  .feature-card__haze {
    top: auto;
    bottom: -18%;
    left: 50%;
    width: 58%;
    height: 42%;
    transform: translateX(-50%);
    background: radial-gradient(circle, rgba(238, 246, 255, 0.2), transparent 70%);
    filter: blur(24px);
    opacity: 0.48;
  }

  .feature-card__veil {
    background:
      radial-gradient(circle at 15% 18%, var(--card-glow), transparent 28%),
      linear-gradient(180deg, rgba(4, 8, 18, 0.12) 0%, rgba(4, 9, 18, 0.22) 40%, rgba(3, 7, 16, 0.82) 100%);
  }

  .feature-card__content {
    position: relative;
    z-index: 2;
    display: grid;
    gap: 0.78rem;
    padding: 1.45rem 1.45rem 1.35rem;
    max-width: 27rem;
  }

  .feature-card__status {
    display: inline-flex;
    align-items: center;
    justify-self: start;
    min-height: 2rem;
    padding: 0.3rem 0.72rem;
    border-radius: 999px;
    background: var(--status-bg);
    border: 1px solid var(--status-border);
    color: var(--status-text);
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .feature-card h2 {
    margin: 0;
    font-family: "Space Grotesk", "Segoe UI", sans-serif;
    font-size: clamp(1.95rem, 3vw, 2.65rem);
    line-height: 0.96;
    letter-spacing: -0.05em;
  }

  .feature-card p {
    margin: 0;
    font-size: 1.05rem;
    line-height: 1.45;
    color: rgba(239, 245, 255, 0.86);
    max-width: 23rem;
  }

  .feature-card__button {
    display: inline-flex;
    align-items: center;
    justify-self: start;
    gap: 0.5rem;
    min-height: 44px;
    margin-top: 0.15rem;
    padding: 0.82rem 1.12rem;
    border-radius: 999px;
    background: linear-gradient(135deg, var(--button-start), var(--button-end));
    color: #ffffff;
    font-weight: 700;
    box-shadow: 0 18px 30px var(--card-shadow);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  :global(html[data-theme="light"]) .landing-shell::before {
    background:
      radial-gradient(circle at 16% 18%, rgba(166, 119, 255, 0.12), transparent 24%),
      radial-gradient(circle at 84% 18%, rgba(72, 148, 255, 0.14), transparent 30%),
      linear-gradient(180deg, rgba(255, 255, 255, 0) 0%, rgba(236, 242, 250, 0.82) 48%, rgba(228, 236, 247, 0.9) 100%);
  }

  :global(html[data-theme="light"]) .landing-shell__brand-veil {
    opacity: 0.12;
  }

  :global(html[data-theme="light"]) .landing-hero__frame {
    box-shadow: 0 34px 78px rgba(17, 32, 51, 0.1);
  }

  :global(html[data-theme="light"]) .landing-search {
    background: rgba(255, 255, 255, 0.42);
    border-color: rgba(26, 55, 93, 0.08);
    box-shadow:
      0 24px 45px rgba(17, 32, 51, 0.16),
      inset 0 1px 0 rgba(255, 255, 255, 0.45);
  }

  :global(html[data-theme="light"]) .landing-search input {
    color: #18304b;
  }

  :global(html[data-theme="light"]) .landing-search input::placeholder {
    color: rgba(57, 78, 108, 0.62);
  }

  :global(html[data-theme="light"]) .landing-search button {
    color: #224262;
  }

  :global(html[data-theme="light"]) .landing-sections__eyebrow {
    color: rgba(31, 55, 92, 0.72);
  }

  :global(html[data-theme="light"]) .landing-sections__eyebrow span {
    color: #102037;
  }

  @media (max-width: 960px) {
    .landing-hero__frame {
      min-height: 36rem;
    }

    .landing-hero__content {
      padding-bottom: 9.5rem;
    }

    .landing-sections {
      margin-top: -5rem;
    }

    .landing-cards {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .landing-shell__brand-veil {
      inset: 8rem 0 auto;
      height: 18rem;
      background-size: 48rem;
      opacity: 0.12;
    }

    .landing-hero {
      padding-top: 0.5rem;
    }

    .landing-hero__frame {
      min-height: 34rem;
    }

    .landing-hero__panel--starsavior,
    .landing-hero__panel--lagrange {
      width: 100%;
      clip-path: none;
    }

    .landing-hero__panel--chaos {
      width: 100%;
      height: 38%;
      clip-path: none;
      opacity: 0.42;
    }

    .landing-hero__panel--lagrange {
      opacity: 0.55;
    }

    .landing-hero__beam {
      left: auto;
      right: 14%;
      width: 22%;
      transform: rotate(14deg);
    }

    .landing-hero__content {
      width: min(var(--content), calc(100% - 1.5rem));
      padding: 6rem 0 4rem;
    }

    .landing-search {
      width: 100%;
      padding-left: 1.1rem;
    }

    .landing-search input {
      font-size: 1rem;
    }

    .landing-sections {
      margin-top: 1.25rem;
    }

    .landing-cards {
      grid-template-columns: 1fr;
    }

    .landing-sections__eyebrow {
      font-size: 1rem;
    }

    .feature-card {
      min-height: 16rem;
    }

    .feature-card__content {
      padding: 1.25rem;
    }
  }
</style>
