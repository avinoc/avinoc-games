---
import GameLayout from "../../../layouts/GameLayout.astro";
import DraftBadge from "../../../components/shared/DraftBadge.astro";
import { getPremiumBuildGuide, saviors } from "../../../data/starsavior/content";
import { formatDisplayDate, getBuildForSavior, getTierRank } from "../../../data/starsavior/relations";

const base = import.meta.env.BASE_URL;
const attributeOrder = ["Sun", "Moon", "Star", "Order", "Chaos"] as const;
const classOrder = ["Assassin", "Caster", "Defender", "Ranger", "Striker", "Supporter"] as const;
const ratingModeOptions = [
  { value: "pve", label: "PvE" },
  { value: "pvp", label: "PvP" },
] as const;
type RatingMode = (typeof ratingModeOptions)[number]["value"];
const roleOptions = [
  { value: "all", label: "All" },
  { value: "attacker", label: "Attacker" },
  { value: "defender", label: "Defender" },
  { value: "support", label: "Support" },
  { value: "healer", label: "Healer" },
] as const;
const rarityOptions = [
  { value: "all", label: "All" },
  { value: "SSR", label: "SSR" },
  { value: "SR", label: "SR" },
  { value: "Reference", label: "Reference" },
] as const;
const ratingTierOrder = ["SSS", "SS", "S+", "S", "A", "B", "C", "NR"] as const;
const tierDescriptions: Record<string, string> = {
  SSS: "The most dominant premium-guide performers in the current premium-guide roster.",
  SS: "Top-end anchors with excellent returns across most account plans.",
  "S+": "High-impact picks that sit just below the absolute best-in-slot band.",
  S: "Strong progression and specialist pieces with consistent value.",
  A: "Useful role players that become better in the right shell or matchup.",
  B: "More situational units with narrower payoff than the upper bands.",
  C: "Low-priority or highly niche options in the current roster window.",
  NR: "Included for completeness when a matching build-guide score is unavailable.",
};
const tierStyles: Record<string, { accent: string; tile: string }> = {
  SSS: {
    accent: "linear-gradient(135deg, rgba(255, 137, 201, 0.98), rgba(255, 185, 121, 0.92))",
    tile: "linear-gradient(135deg, rgba(255, 115, 176, 0.62), rgba(252, 154, 92, 0.52))",
  },
  SS: {
    accent: "linear-gradient(135deg, rgba(255, 166, 119, 0.98), rgba(255, 219, 117, 0.92))",
    tile: "linear-gradient(135deg, rgba(255, 156, 96, 0.55), rgba(255, 209, 111, 0.45))",
  },
  "S+": {
    accent: "linear-gradient(135deg, rgba(255, 218, 117, 0.98), rgba(188, 228, 116, 0.9))",
    tile: "linear-gradient(135deg, rgba(255, 208, 104, 0.5), rgba(178, 220, 103, 0.4))",
  },
  S: {
    accent: "linear-gradient(135deg, rgba(122, 214, 255, 0.98), rgba(131, 166, 255, 0.92))",
    tile: "linear-gradient(135deg, rgba(88, 198, 255, 0.52), rgba(118, 144, 255, 0.42))",
  },
  A: {
    accent: "linear-gradient(135deg, rgba(120, 235, 156, 0.98), rgba(66, 197, 212, 0.9))",
    tile: "linear-gradient(135deg, rgba(104, 226, 150, 0.48), rgba(58, 188, 205, 0.38))",
  },
  B: {
    accent: "linear-gradient(135deg, rgba(152, 208, 255, 0.98), rgba(121, 135, 255, 0.92))",
    tile: "linear-gradient(135deg, rgba(125, 185, 255, 0.46), rgba(106, 116, 235, 0.36))",
  },
  C: {
    accent: "linear-gradient(135deg, rgba(173, 183, 255, 0.98), rgba(121, 114, 220, 0.92))",
    tile: "linear-gradient(135deg, rgba(150, 162, 255, 0.42), rgba(108, 101, 214, 0.32))",
  },
  NR: {
    accent: "linear-gradient(135deg, rgba(163, 173, 197, 0.98), rgba(108, 126, 157, 0.9))",
    tile: "linear-gradient(135deg, rgba(149, 158, 185, 0.4), rgba(103, 118, 144, 0.32))",
  },
};

function normalizeImage(src?: string) {
  if (!src) return undefined;
  if (/^https?:\/\//i.test(src)) return src;
  if (src.startsWith("/assets/starsavior/starsavior/")) return src;
  if (src.startsWith("/assets/starsavior/")) {
    return src.replace("/assets/starsavior/", "/assets/starsavior/starsavior/");
  }
  return src;
}

function getAttribute(entry: (typeof saviors)[number]) {
  return attributeOrder.find((attribute) => entry.mode.includes(attribute) || entry.tags.includes(attribute)) || "Star";
}

function getUnitClass(entry: (typeof saviors)[number]) {
  return classOrder.find((unitClass) => entry.mode.includes(unitClass) || entry.tags.includes(unitClass)) || "Supporter";
}

function getRarity(entry: (typeof saviors)[number]) {
  if (entry.tags.includes("Reference Only")) return "Reference";
  if (entry.tags.includes("SSR")) return "SSR";
  if (entry.tags.includes("SR")) return "SR";
  return "Reference";
}

function getRoleFilters(entry: (typeof saviors)[number], unitClass: string, buildRole?: string, summaryText?: string) {
  const summary = `${entry.mode} ${entry.tags.join(" ")} ${summaryText || entry.summary} ${buildRole || ""}`;
  const roles = new Set<string>();

  if (["Assassin", "Caster", "Ranger", "Striker"].includes(unitClass)) roles.add("attacker");
  if (unitClass === "Defender" || entry.tags.includes("Tank")) roles.add("defender");
  if (unitClass === "Supporter" || /support|buff|debuff|action gauge/i.test(summary) || entry.tags.includes("Support")) roles.add("support");
  if (/heal|recovery|self-sustain|sustain/i.test(summary)) roles.add("healer");
  if (roles.size === 0) roles.add("attacker");

  return [...roles];
}

function getRoleLabel(roleFilters: string[]) {
  if (roleFilters.includes("support")) return "Support";
  if (roleFilters.includes("healer")) return "Healer";
  if (roleFilters.includes("defender")) return "Defender";
  return "Attacker";
}

function getRatingValue(ratings: { label: string; value: string }[] = [], label: string) {
  return ratings.find((rating) => rating.label.toLowerCase() === label.toLowerCase())?.value;
}

function pickBestTier(values: Array<string | undefined>) {
  const available = values.filter((value): value is string => Boolean(value));
  if (available.length === 0) return "NR";
  return available.sort((a, b) => getTierRank(a, ratingTierOrder) - getTierRank(b, ratingTierOrder))[0];
}

function getModeTier(ratings: { label: string; value: string }[] = [], mode: RatingMode) {
  if (mode === "pve") {
    return getRatingValue(ratings, "PvE") || pickBestTier([getRatingValue(ratings, "Campaign"), getRatingValue(ratings, "Boss"), getRatingValue(ratings, "Overall")]);
  }

  return getRatingValue(ratings, "PvP") || pickBestTier([getRatingValue(ratings, "Ranked"), getRatingValue(ratings, "Strategy"), getRatingValue(ratings, "Overall")]);
}

function getModeRatingSource(ratings: { label: string; value: string }[] = [], mode: RatingMode) {
  if (mode === "pve") {
    if (getRatingValue(ratings, "PvE")) return "Uses the direct PvE score from the premium build guide.";
    if (getRatingValue(ratings, "Campaign") || getRatingValue(ratings, "Boss")) {
      return "Uses the stronger of the guide's Campaign and Boss ratings to represent PvE.";
    }
    return "Falls back to the guide's Overall score because no dedicated PvE labels were present.";
  }

  if (getRatingValue(ratings, "PvP")) return "Uses the direct PvP score from the premium build guide.";
  if (getRatingValue(ratings, "Ranked") || getRatingValue(ratings, "Strategy")) {
    return "Uses the stronger of the guide's Ranked and Strategy ratings to represent PvP.";
  }
  return "Falls back to the guide's Overall score because no dedicated PvP labels were present.";
}

function getTierWeight(tier: string) {
  return Math.max(1, ratingTierOrder.length - getTierRank(tier, ratingTierOrder));
}

const initialEntries = saviors.map((entry) => {
  const build = getBuildForSavior(entry.slug);
  const premiumBuild = build ? getPremiumBuildGuide(build.slug) : undefined;
  const ratings = premiumBuild?.hero.ratings || [];
  const pveTier = getModeTier(ratings, "pve");
  const pvpTier = getModeTier(ratings, "pvp");
  const summaryText = premiumBuild?.combatIdentity.summary || premiumBuild?.hero.summary || entry.summary;
  const attribute = getAttribute(entry);
  const unitClass = getUnitClass(entry);
  const roleFilters = getRoleFilters(entry, unitClass, build?.role, summaryText);
  const roleLabel = getRoleLabel(roleFilters);
  const rarity = getRarity(entry);
  const avatarImage = normalizeImage(build?.image || premiumBuild?.hero.image || entry.image);
  const heroImage = normalizeImage(premiumBuild?.hero.image || build?.image || entry.image);
  const coreSet = build?.recommendedSets?.[0];
  const alternateSet = build?.recommendedSets?.[1];
  const searchText = `${entry.name} ${entry.mode} ${entry.tags.join(" ")} ${summaryText} ${build?.role || ""} ${pveTier} ${pvpTier}`.toLowerCase();

  return {
    ...entry,
    build,
    premiumBuild,
    attribute,
    unitClass,
    roleFilters,
    roleLabel,
    rarity,
    avatarImage,
    heroImage,
    coreSet,
    alternateSet,
    summaryText,
    pveTier,
    pvpTier,
    pveSourceNote: getModeRatingSource(ratings, "pve"),
    pvpSourceNote: getModeRatingSource(ratings, "pvp"),
    searchText,
    buildHref: build ? `${base}starsavior/builds/${build.slug}/` : undefined,
    guideStatus: premiumBuild?.status || build?.status || entry.status,
    guideUpdatedAt: premiumBuild?.updatedAt || build?.updatedAt || entry.updatedAt,
  };
});

const entries = initialEntries.map((entry) => {
  const pairings = initialEntries
    .filter((candidate) => candidate.slug !== entry.slug)
    .map((candidate) => {
      let score = getTierWeight(pickBestTier([candidate.pveTier, candidate.pvpTier])) * 5;

      if (candidate.attribute === entry.attribute) score += 7;
      if (candidate.roleLabel !== entry.roleLabel) score += 4;
      if (entry.roleFilters.includes("attacker") && (candidate.roleFilters.includes("support") || candidate.roleFilters.includes("healer"))) score += 5;
      if (entry.roleFilters.includes("support") && candidate.roleFilters.includes("attacker")) score += 4;
      if (entry.roleFilters.includes("defender") && candidate.roleFilters.includes("healer")) score += 3;
      if (candidate.build) score += 1;

      return { candidate, score };
    })
    .sort((a, b) => b.score - a.score || a.candidate.name.localeCompare(b.candidate.name))
    .slice(0, 6)
    .map(({ candidate }) => candidate);

  return {
    ...entry,
    pairings,
  };
});

const entriesByMode = {
  pve: [...entries].sort((a, b) => getTierRank(a.pveTier, ratingTierOrder) - getTierRank(b.pveTier, ratingTierOrder) || a.name.localeCompare(b.name)),
  pvp: [...entries].sort((a, b) => getTierRank(a.pvpTier, ratingTierOrder) - getTierRank(b.pvpTier, ratingTierOrder) || a.name.localeCompare(b.name)),
};

const groupedByMode = {
  pve: ratingTierOrder.map((tier) => ({ tier, entries: entriesByMode.pve.filter((entry) => entry.pveTier === tier) })).filter((group) => group.entries.length > 0),
  pvp: ratingTierOrder.map((tier) => ({ tier, entries: entriesByMode.pvp.filter((entry) => entry.pvpTier === tier) })).filter((group) => group.entries.length > 0),
};

const modeBoards = ratingModeOptions.map((mode) => ({
  ...mode,
  featured: entriesByMode[mode.value].find((entry) => entry.build) || entriesByMode[mode.value][0] || null,
  groups: groupedByMode[mode.value],
}));

const defaultFeatured = modeBoards.find((board) => board.value === "pve")?.featured || modeBoards[0]?.featured || entries[0] || null;
const reviewStatus = entries.some((entry) => entry.guideStatus !== "published") ? "needs-review" : "published";
const latestUpdatedAtRaw = entries.reduce((latest, entry) => (entry.guideUpdatedAt > latest ? entry.guideUpdatedAt : latest), "2026-04-03");
const updatedAt = formatDisplayDate(latestUpdatedAtRaw);
---

<GameLayout
  title="Savior Tier List Tool | Project Avinoc"
  description="Dashboard-style Star Savior tier list driven by premium build-guide PvE and PvP ratings, with filters and a selected-hero build sidebar."
  game="starsavior"
  hideSubnav={true}
>
  <div class="ss-tier-shell">
    <div class="ss-tier-shell__noise" aria-hidden="true"></div>

    <section class="container ss-tier-stage">
      <header class="ss-tier-head">
        <p class="ss-tier-kicker">Published tier data · Updated {updatedAt}</p>
        <h1>Star Savior Hero Tier List Tool</h1>
        <p class="ss-tier-summary">
          This board now reads from the published premium build guides. Use the toggle to swap between <strong>PvE</strong> and <strong>PvP</strong> rankings, with each band derived from the guide ratings rather than the older sheet-era tier export.
        </p>
      </header>

      <div class="ss-filter-stack">
        <DraftBadge status={reviewStatus} placement="inline" />

        <div class="ss-filter-group" role="group" aria-label="Switch tier mode">
          <span class="ss-filter-group__label">Mode</span>
          {ratingModeOptions.map((mode, index) => (
            <button
              class:list={["ss-chip", "ss-chip--mode", index === 0 && "is-active"]}
              type="button"
              data-mode-toggle
              data-mode-value={mode.value}
              aria-pressed={index === 0 ? "true" : "false"}
            >
              {mode.label}
            </button>
          ))}
        </div>

        <div class="ss-filter-group" role="group" aria-label="Filter by attribute">
          <span class="ss-filter-group__label">Attribute</span>
          <button class="ss-chip is-active" type="button" data-filter-group="attribute" data-filter-value="all" aria-pressed="true">All</button>
          {attributeOrder.map((attribute) => (
            <button class="ss-chip" type="button" data-filter-group="attribute" data-filter-value={attribute} aria-pressed="false">
              {attribute}
            </button>
          ))}
        </div>

        <div class="ss-filter-group" role="group" aria-label="Filter by role">
          <span class="ss-filter-group__label">Role</span>
          {roleOptions.map((role, index) => (
            <button
              class:list={["ss-chip", index === 0 && "is-active"]}
              type="button"
              data-filter-group="role"
              data-filter-value={role.value}
              aria-pressed={index === 0 ? "true" : "false"}
            >
              {role.label}
            </button>
          ))}
        </div>

        <div class="ss-filter-group" role="group" aria-label="Filter by rarity">
          <span class="ss-filter-group__label">Rarity</span>
          {rarityOptions.map((rarity, index) => (
            <button
              class:list={["ss-chip", index === 0 && "is-active"]}
              type="button"
              data-filter-group="rarity"
              data-filter-value={rarity.value}
              aria-pressed={index === 0 ? "true" : "false"}
            >
              {rarity.label}
            </button>
          ))}
        </div>

        <label class="ss-search-chip">
          <span>Search</span>
          <input id="savior-tier-search" type="search" placeholder="Name, role, tags, notes" />
        </label>
      </div>

      {modeBoards.map((board, boardIndex) => (
        <div class:list={["ss-tier-layout", boardIndex !== 0 && "is-hidden"]} data-mode-layout={board.value} hidden={boardIndex !== 0}>
          <section class="ss-board-panel">
            <div class="ss-board-panel__head">
              <div>
                <p class="ss-section-label">Tier Board</p>
                <h2>{board.label} ranked bands</h2>
              </div>
              <p class="ss-board-panel__note">Select any Savior portrait to update the {board.label} guide panel.</p>
            </div>

            <div class="ss-tier-board">
              {board.groups.map((group) => (
                <section
                  class="ss-tier-row"
                  data-tier-group={group.tier}
                  data-mode={board.value}
                  style={`--tier-accent:${tierStyles[group.tier].accent}; --tier-tile:${tierStyles[group.tier].tile};`}
                >
                  <div class="ss-tier-row__label">
                    <strong>{group.tier}</strong>
                    <p>{tierDescriptions[group.tier]}</p>
                  </div>

                  <div class="ss-tier-row__track">
                    {group.entries.map((entry) => {
                      const currentTier = board.value === "pve" ? entry.pveTier : entry.pvpTier;

                      return (
                        <button
                          class:list={["ss-avatar-tile", entry.slug === board.featured?.slug && "is-selected"]}
                          type="button"
                          title={entry.name}
                          aria-label={`${entry.name}, ${board.label} tier ${currentTier}`}
                          aria-pressed={entry.slug === board.featured?.slug ? "true" : "false"}
                          data-savior-button
                          data-mode={board.value}
                          data-savior-slug={entry.slug}
                          data-tier={currentTier}
                          data-attribute={entry.attribute}
                          data-role={entry.roleFilters.join(",")}
                          data-rarity={entry.rarity}
                          data-search={entry.searchText}
                        >
                          {entry.avatarImage ? (
                            <img src={entry.avatarImage} alt="" loading="lazy" />
                          ) : (
                            <span>{entry.name.slice(0, 2).toUpperCase()}</span>
                          )}

                          <span class="ss-avatar-tile__meta">
                            <small>{entry.rarity}</small>
                            <small>{currentTier}</small>
                          </span>
                        </button>
                      );
                    })}
                  </div>
                </section>
              ))}
            </div>

            <div class="ss-empty-state" data-empty-state-mode={board.value} hidden>
              <strong>No saviors match the current filters.</strong>
              <p>Clear one of the chips or search terms to repopulate the tier board.</p>
            </div>

            <div class="ss-source-note">
              <strong>Source note</strong>
              <p>
                Ranks come from the published premium build guides. PvE uses the direct <code>PvE</code> score when it exists, otherwise the stronger of <code>Campaign</code> and <code>Boss</code>. PvP uses the direct <code>PvP</code> score when it exists, otherwise the stronger of <code>Ranked</code> and <code>Strategy</code>.
              </p>
            </div>
          </section>

          <aside class="ss-sidebar">
            {entries.map((entry) => {
              const currentTier = board.value === "pve" ? entry.pveTier : entry.pvpTier;
              const currentSourceNote = board.value === "pve" ? entry.pveSourceNote : entry.pvpSourceNote;

              return (
                <article
                  class:list={["ss-sidebar-panel", entry.slug === board.featured?.slug && "is-active"]}
                  data-savior-panel
                  data-mode={board.value}
                  data-savior-slug={entry.slug}
                  aria-hidden={entry.slug === board.featured?.slug ? "false" : "true"}
                >
                  <div class="ss-sidebar-hero" style={`--hero-accent:${tierStyles[currentTier].accent};`}>
                    {entry.heroImage ? (
                      <img src={entry.heroImage} alt={`${entry.name} artwork`} loading="lazy" />
                    ) : (
                      <div class="ss-sidebar-hero__fallback">{entry.name.slice(0, 2).toUpperCase()}</div>
                    )}

                    <div class="ss-sidebar-hero__overlay"></div>
                    <div class="ss-sidebar-hero__body">
                      <div class="ss-sidebar-hero__chips">
                        <span>{entry.attribute}</span>
                        <span>{entry.unitClass}</span>
                        <span>{entry.rarity}</span>
                      </div>
                      <h2>{entry.name}</h2>
                      <p>{entry.mode}</p>
                    </div>
                  </div>

                  <section class="ss-sidebar-section">
                    <div class="ss-sidebar-section__head">
                      <h3>Build Guide</h3>
                      {entry.buildHref && <a href={entry.buildHref}>Open build</a>}
                    </div>

                    {entry.build ? (
                      <div class="ss-guide-stack">
                        <a class="ss-guide-card" href={entry.buildHref}>
                          <span class="ss-guide-card__label">Recommended sets</span>
                          <strong>{entry.coreSet?.sets.join(" + ") || "Open build page"}</strong>
                          {entry.coreSet && <small>{entry.coreSet.neckMain} neck · {entry.coreSet.ringMain} ring</small>}
                        </a>

                        <div class="ss-guide-card ss-guide-card--static">
                          <span class="ss-guide-card__label">Arcana</span>
                          <strong>{entry.build.arcana.slice(0, 2).join(" / ") || "Open build page"}</strong>
                          <small>{entry.build.skillLevels.endgame} endgame skill line</small>
                        </div>

                        {entry.alternateSet && (
                          <div class="ss-guide-card ss-guide-card--static">
                            <span class="ss-guide-card__label">{entry.alternateSet.label}</span>
                            <strong>{entry.alternateSet.sets.join(" + ")}</strong>
                            <small>{entry.alternateSet.neckMain} neck · {entry.alternateSet.ringMain} ring</small>
                          </div>
                        )}
                      </div>
                    ) : (
                      <div class="ss-guide-empty">
                        <strong>No linked build page yet.</strong>
                        <p>This entry is still kept on the board so the roster stays complete even when a dedicated build write-up is not published yet.</p>
                      </div>
                    )}
                  </section>

                  <section class="ss-sidebar-section">
                    <div class="ss-sidebar-section__head">
                      <h3>Roster Pairings</h3>
                      <span>Suggested coverage</span>
                    </div>
                    <p class="ss-sidebar-copy">Suggested using shared attribute pressure and complementary role coverage, not a fixed published team list.</p>

                    <div class="ss-pairing-grid">
                      {entry.pairings.map((pairing) => (
                        <button
                          class="ss-pairing-tile"
                          type="button"
                          title={`Select ${pairing.name}`}
                          data-pairing-target={pairing.slug}
                          data-mode={board.value}
                        >
                          {pairing.avatarImage ? (
                            <img src={pairing.avatarImage} alt="" loading="lazy" />
                          ) : (
                            <span>{pairing.name.slice(0, 2).toUpperCase()}</span>
                          )}
                          <strong>{pairing.name}</strong>
                          <small>{pairing.roleLabel}</small>
                        </button>
                      ))}
                    </div>
                  </section>

                  <section class="ss-sidebar-section">
                    <div class="ss-sidebar-section__head">
                      <h3>{board.label} Notes</h3>
                      <span>{board.label} {currentTier}</span>
                    </div>
                    <p class="ss-sidebar-copy">{entry.summaryText}</p>
                    <p class="ss-sidebar-copy ss-sidebar-copy--caption">{currentSourceNote}</p>
                    <div class="ss-rating-pill-row">
                      <span class:list={["ss-inline-rating", board.value === "pve" && "is-active"]}>PvE {entry.pveTier}</span>
                      <span class:list={["ss-inline-rating", board.value === "pvp" && "is-active"]}>PvP {entry.pvpTier}</span>
                    </div>
                    <div class="ss-tag-row">
                      {entry.tags.slice(0, 6).map((tag) => (
                        <span class="ss-tag">{tag}</span>
                      ))}
                    </div>
                  </section>
                </article>
              );
            })}

            <article class="ss-sidebar-empty" data-sidebar-empty-mode={board.value} hidden>
              <h2>No matching Savior</h2>
              <p>There isn&apos;t a selected result because the current filters hide the full roster.</p>
            </article>
          </aside>
        </div>
      ))}
    </section>
  </div>

  <script is:inline define:vars={{ defaultSlug: defaultFeatured?.slug ?? "" }}>
    const searchInput = document.querySelector("#savior-tier-search");
    const modeButtons = Array.from(document.querySelectorAll("[data-mode-toggle]"));
    const modeLayouts = Array.from(document.querySelectorAll("[data-mode-layout]"));
    const filterButtons = Array.from(document.querySelectorAll("[data-filter-group]"));
    const saviorButtons = Array.from(document.querySelectorAll("[data-savior-button]"));
    const saviorPanels = Array.from(document.querySelectorAll("[data-savior-panel]"));
    const tierGroups = Array.from(document.querySelectorAll("[data-tier-group]"));
    const emptyStates = Array.from(document.querySelectorAll("[data-empty-state-mode]"));
    const sidebarEmpties = Array.from(document.querySelectorAll("[data-sidebar-empty-mode]"));
    const pairingButtons = Array.from(document.querySelectorAll("[data-pairing-target]"));

    const state = {
      mode: "pve",
      attribute: "all",
      role: "all",
      rarity: "all",
      selected: window.location.hash.slice(1) || defaultSlug,
    };

    function getModeSaviorButtons() {
      return saviorButtons.filter((button) => button.dataset.mode === state.mode);
    }

    function getModeSaviorPanels() {
      return saviorPanels.filter((panel) => panel.dataset.mode === state.mode);
    }

    function getModeTierGroups() {
      return tierGroups.filter((group) => group.dataset.mode === state.mode);
    }

    function getModeEmptyState() {
      return emptyStates.find((element) => element.dataset.emptyStateMode === state.mode);
    }

    function getModeSidebarEmpty() {
      return sidebarEmpties.find((element) => element.dataset.sidebarEmptyMode === state.mode);
    }

    function getVisibleButtons() {
      return getModeSaviorButtons().filter((button) => !button.hidden);
    }

    function syncModeButtons() {
      modeButtons.forEach((button) => {
        const active = button.dataset.modeValue === state.mode;
        button.classList.toggle("is-active", active);
        button.setAttribute("aria-pressed", active ? "true" : "false");
      });
    }

    function syncModeLayouts() {
      modeLayouts.forEach((layout) => {
        const active = layout.dataset.modeLayout === state.mode;
        layout.hidden = !active;
        layout.classList.toggle("is-hidden", !active);
      });
    }

    function syncFilterButtons() {
      filterButtons.forEach((button) => {
        const group = button.dataset.filterGroup;
        const value = button.dataset.filterValue;
        const active = state[group] === value;
        button.classList.toggle("is-active", active);
        button.setAttribute("aria-pressed", active ? "true" : "false");
      });
    }

    function matches(button) {
      const query = (searchInput?.value || "").trim().toLowerCase();
      const attributeMatch = state.attribute === "all" || button.dataset.attribute === state.attribute;
      const rarityMatch = state.rarity === "all" || button.dataset.rarity === state.rarity;
      const roleValues = (button.dataset.role || "").split(",").filter(Boolean);
      const roleMatch = state.role === "all" || roleValues.includes(state.role);
      const searchMatch = !query || (button.dataset.search || "").includes(query);
      return attributeMatch && rarityMatch && roleMatch && searchMatch;
    }

    function activateSelected(slug) {
      saviorButtons.forEach((button) => {
        const active = button.dataset.mode === state.mode && button.dataset.saviorSlug === slug && !button.hidden;
        button.classList.toggle("is-selected", active);
        button.setAttribute("aria-pressed", active ? "true" : "false");
      });

      saviorPanels.forEach((panel) => {
        const active = panel.dataset.mode === state.mode && panel.dataset.saviorSlug === slug;
        panel.classList.toggle("is-active", active);
        panel.setAttribute("aria-hidden", active ? "false" : "true");
      });

      state.selected = slug;
      if (slug) history.replaceState(null, "", `#${slug}`);
    }

    function updateBoard() {
      getModeSaviorButtons().forEach((button) => {
        button.hidden = !matches(button);
      });

      getModeTierGroups().forEach((group) => {
        const visibleCount = group.querySelectorAll(`[data-savior-button][data-mode="${state.mode}"]:not([hidden])`).length;
        group.hidden = visibleCount === 0;
      });

      const visibleButtons = getVisibleButtons();
      const hasVisible = visibleButtons.length > 0;
      const emptyState = getModeEmptyState();
      const sidebarEmpty = getModeSidebarEmpty();

      if (emptyState) emptyState.hidden = hasVisible;
      if (sidebarEmpty) sidebarEmpty.hidden = hasVisible;

      if (!hasVisible) {
        getModeSaviorPanels().forEach((panel) => {
          panel.classList.remove("is-active");
          panel.setAttribute("aria-hidden", "true");
        });
      } else if (!visibleButtons.some((button) => button.dataset.saviorSlug === state.selected)) {
        activateSelected(visibleButtons[0].dataset.saviorSlug);
      } else {
        activateSelected(state.selected);
      }

      syncFilterButtons();
      syncModeButtons();
      syncModeLayouts();
    }

    modeButtons.forEach((button) => {
      button.addEventListener("click", () => {
        state.mode = button.dataset.modeValue || "pve";
        updateBoard();
      });
    });

    filterButtons.forEach((button) => {
      button.addEventListener("click", () => {
        state[button.dataset.filterGroup] = button.dataset.filterValue;
        updateBoard();
      });
    });

    saviorButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const slug = button.dataset.saviorSlug;
        if (slug) activateSelected(slug);
      });
    });

    pairingButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const slug = button.dataset.pairingTarget;
        const nextButton = getModeSaviorButtons().find((candidate) => candidate.dataset.saviorSlug === slug && !candidate.hidden);
        if (slug && nextButton) {
          activateSelected(slug);
          nextButton.scrollIntoView({ block: "nearest", inline: "nearest", behavior: "smooth" });
        }
      });
    });

    searchInput?.addEventListener("input", updateBoard);

    window.addEventListener("hashchange", () => {
      const slug = window.location.hash.slice(1);
      const nextButton = getModeSaviorButtons().find((button) => button.dataset.saviorSlug === slug && !button.hidden);
      if (slug && nextButton) activateSelected(slug);
    });

    if (!getModeSaviorButtons().some((button) => button.dataset.saviorSlug === state.selected)) {
      state.selected = defaultSlug;
    }

    updateBoard();
  </script>

