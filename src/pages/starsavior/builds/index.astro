---
import GameLayout from "../../../layouts/GameLayout.astro";
import Hero from "../../../components/starsavior/Hero.astro";
import BuildCard from "../../../components/starsavior/BuildCard.astro";
import { builds } from "../../../data/starsavior/content";

const sortedBuilds = [...builds].sort((a, b) => a.name.localeCompare(b.name));
const roles = [...new Set(sortedBuilds.map((entry) => entry.role))].sort((a, b) => a.localeCompare(b));
---

<GameLayout title="Builds | StarSavior Atlas" description="Curated Savior build cards with set recommendations, skill breakpoints, and Journey notes." game="starsavior">
  <Hero
    title="Curated build cards for launch units."
    summary="The build pages now pull portraits and recommendation art from the published sheet while keeping the routing advice readable in English: sets, substats, skill breakpoints, and Journey card plans."
  />

  <section class="container stack">
    <div class="panel" style="padding: 1.4rem;">
      <div class="filter-bar sticky-filter-bar">
        <input id="build-search" type="search" placeholder="Search builds..." />
        <select id="build-role">
          <option value="all">All roles</option>
          {roles.map((role) => (
            <option value={role}>{role}</option>
          ))}
        </select>
      </div>

      <div class="card-grid" id="build-grid">
        {sortedBuilds.map((entry) => (
          <BuildCard entry={entry} />
        ))}
      </div>
    </div>
  </section>

  <script is:inline>
    const searchInput = document.querySelector("#build-search");
    const roleSelect = document.querySelector("#build-role");
    const cards = [...document.querySelectorAll(".build-card")];
    const params = new URLSearchParams(window.location.search);

    if (searchInput && params.get("q")) {
      searchInput.value = params.get("q");
    }

    if (roleSelect && params.get("role")) {
      roleSelect.value = params.get("role");
    }

    const update = () => {
      const query = searchInput?.value.toLowerCase().trim() ?? "";
      const role = roleSelect?.value ?? "all";
      const nextParams = new URLSearchParams(window.location.search);

      cards.forEach((card) => {
        const text = card.textContent?.toLowerCase() ?? "";
        const roleMatch = role === "all" || card.dataset.role === role;
        const searchMatch = !query || text.includes(query);
        card.classList.toggle("hidden", !(roleMatch && searchMatch));
      });

      if (query) {
        nextParams.set("q", query);
      } else {
        nextParams.delete("q");
      }

      if (role !== "all") {
        nextParams.set("role", role);
      } else {
        nextParams.delete("role");
      }

      const nextUrl = `${window.location.pathname}${nextParams.toString() ? `?${nextParams.toString()}` : ""}`;
      window.history.replaceState({}, "", nextUrl);
    };

    searchInput?.addEventListener("input", update);
    roleSelect?.addEventListener("change", update);
    update();
  </script>
</GameLayout>
