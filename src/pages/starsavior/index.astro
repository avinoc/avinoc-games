---
import GameLayout from "../../layouts/GameLayout.astro";
import sourceSheet from "../../content/starsavior/sources/starsavior-sheet.json";

const base = import.meta.env.BASE_URL;
const reviewedOn = new Date(`${sourceSheet.lastReviewed}T00:00:00`).toLocaleDateString("en-US", {
  month: "short",
  day: "numeric",
  year: "numeric",
});

const heroStats = [
  { value: "1", label: "Premium build live" },
  { value: "2", label: "Tier list pages live" },
  { value: "7", label: "Guide routes in review" },
];

const heroActions = [
  { href: `${base}starsavior/start-here/`, label: "Start Here", external: false },
  { href: `${base}starsavior/builds/`, label: "Build Guides", external: false },
  { href: `${base}starsavior/tier-lists/saviors/`, label: "Hero Tier List", tone: "secondary", external: false },
];

const resourceCards = [
  {
    title: "Hero Tier List",
    eyebrow: "Roster Priority",
    summary: "42 saviors ranked for PvE and PvP with quick role tags and direct build paths.",
    href: `${base}starsavior/tier-lists/saviors/`,
    cta: "Explore",
    meta: "Updated rankings",
    art: "collage",
    image: `${base}assets/home/starsavior-card.jpg`,
  },
  {
    title: "Progression Guide",
    eyebrow: "New Account Route",
    summary: "Follow the reroll, starter, team-building, and CP route in the order that actually unlocks progress.",
    href: `${base}starsavior/start-here/`,
    cta: "Open route",
    meta: "4-step opener",
    art: "progression",
  },
  {
    title: "Gear Guide",
    eyebrow: "Build Systems",
    summary: "Learn set planning, upgrade breakpoints, and what to farm before you waste rare materials.",
    href: `${base}starsavior/guides/gear/`,
    cta: "Read guide",
    meta: "Gear + substats",
    art: "gear",
  },
  {
    title: "Build Guides",
    eyebrow: "Featured Character",
    summary: "Open premium character pages with teams, target stats, skill rotation, and upgrade priorities. Rosaria is live first.",
    href: `${base}starsavior/builds/`,
    cta: "Open builds",
    meta: "Rosaria featured",
    art: "builds",
    characterSrc: `${base}assets/starsavior/starsavior/premium/rosaria/rosaria.webp`,
    badges: ["Teams", "Stats", "Rotation"],
  },
];

const railLinks = [
  {
    title: "Community Sheets",
    description: "Bullet's cited source sheet, kept close for cross-checking and deeper tabs.",
    href: sourceSheet.sheetUrl,
    cta: "Open sheet",
    icon: "community",
    external: true,
    note: `Reviewed ${reviewedOn}`,
  },
  {
    title: "Guides",
    description: "Reroll, starter, gear, team-building, and CP notes without spreadsheet hunting.",
    href: `${base}starsavior/guides/gear/`,
    cta: "Read guides",
    icon: "docs",
  },
  {
    title: "Journey Route",
    description: "Jump straight into the Hard Journey path once the first four pages are done.",
    href: `${base}starsavior/journey/hard-guide/`,
    cta: "Open route",
    icon: "spark",
  },
];

const quickLinks = [
  { label: "Reroll Guide", href: `${base}starsavior/guides/reroll/` },
  { label: "Starter Guide", href: `${base}starsavior/guides/starter-guide/` },
  { label: "Arcana Tier List", href: `${base}starsavior/tier-lists/arcana/` },
  { label: "Build Index", href: `${base}starsavior/builds/` },
];
---

<GameLayout
  title="StarSavior"
  description="Project Avinoc's StarSavior hub for premium builds, tier lists, and route pages."
  game="starsavior"
>
  <div class="starsavior-landing">
    <div class="starsavior-landing__backdrop" aria-hidden="true">
      <span class="starsavior-landing__orb starsavior-landing__orb--violet"></span>
      <span class="starsavior-landing__orb starsavior-landing__orb--blue"></span>
      <span class="starsavior-landing__orb starsavior-landing__orb--rose"></span>
    </div>

    <section class="container starsavior-landing__hero-section">
      <div
        class="landing-banner"
        style={`--banner-image: url("${base}assets/home/starsavior-hero.jpg")`}
      >
        <div class="landing-banner__copy">
          <p class="landing-banner__eyebrow">Project Avinoc</p>
          <h1 class="landing-banner__title">StarSavior</h1>
          <p class="landing-banner__summary">
            Project Avinoc is rebuilding the StarSavior section around premium character guides,
            cleaner route pages, and faster ranking hubs. Rosaria is the first full build live now,
            with the rest of the catalog rolling in behind it.
          </p>

          <div class="landing-banner__actions">
            {heroActions.map((action) => (
              <a
                class:list={[
                  "landing-button",
                  { "landing-button--ghost": action.tone === "secondary" },
                ]}
                href={action.href}
                target={action.external ? "_blank" : undefined}
                rel={action.external ? "noreferrer" : undefined}
              >
                {action.label}
                <span aria-hidden="true">→</span>
              </a>
            ))}
          </div>

          <ul class="landing-banner__stats" role="list">
            {heroStats.map((stat) => (
              <li>
                <strong>{stat.value}</strong>
                <span>{stat.label}</span>
              </li>
            ))}
          </ul>

          <p class="landing-banner__citation">
            Source:
            <a href={sourceSheet.sheetUrl} target="_blank" rel="noreferrer">
              Bullet StarSavior Complete Guide
            </a>
            <span>Reviewed {reviewedOn}</span>
          </p>
        </div>

        <div class="landing-banner__art" aria-hidden="true">
          <div class="landing-banner__beam"></div>
          <img
            class="landing-banner__character landing-banner__character--lead"
            src={`${base}assets/starsavior/starsavior/tychara/079a443f5d9fb1d0e8967ffdbaa0d43ece56955f.webp`}
            alt=""
            loading="eager"
            decoding="async"
          />
          <img
            class="landing-banner__character landing-banner__character--support"
            src={`${base}assets/starsavior/starsavior/tychara/ef3c71dbfca389638ddd94632ccc04fd61e87148.webp`}
            alt=""
            loading="eager"
            decoding="async"
          />
        </div>
      </div>
    </section>

    <section class="container starsavior-landing__resources" aria-labelledby="resource-cards-title">
      <div class="landing-section-head">
        <p class="landing-section-head__eyebrow">
          <span>Resource Cards</span>
          <span>Pick a route to explore</span>
        </p>
        <h2 id="resource-cards-title">Start with the pages players open the most.</h2>
      </div>

      <div class="landing-grid">
        <div class="resource-grid">
          {resourceCards.map((card) => (
            <a
              class={`resource-card resource-card--${card.art}`}
              href={card.href}
              style={card.image ? `--card-image: url("${card.image}")` : undefined}
            >
              <div class="resource-card__copy">
                <p class="resource-card__eyebrow">{card.eyebrow}</p>
                <h3>{card.title}</h3>
                <p>{card.summary}</p>
                <div class="resource-card__footer">
                  <span class="resource-card__cta">{card.cta} <span aria-hidden="true">→</span></span>
                  <span class="resource-card__meta">{card.meta}</span>
                </div>
              </div>

              <div class="resource-card__visual" aria-hidden="true">
                {card.art === "collage" && <div class="resource-card__image-fill"></div>}

                {card.art === "progression" && (
                  <div class="resource-card__progression-visual">
                    <div class="resource-card__glyph resource-card__glyph--progression">
                      <svg viewBox="0 0 180 180" fill="none">
                        <defs>
                          <linearGradient id="scrollFill" x1="34" y1="26" x2="140" y2="150" gradientUnits="userSpaceOnUse">
                            <stop stop-color="#ffe8b9"></stop>
                            <stop offset="1" stop-color="#f3bd76"></stop>
                          </linearGradient>
                          <linearGradient id="scrollStroke" x1="64" y1="18" x2="142" y2="168" gradientUnits="userSpaceOnUse">
                            <stop stop-color="#8c5a29"></stop>
                            <stop offset="1" stop-color="#5c3217"></stop>
                          </linearGradient>
                        </defs>
                        <path d="M42 46c0-12 9-21 21-21h38c20 0 36 16 36 36v48c0 12-10 22-22 22H72c-18 0-32-14-32-32V46Z" fill="url(#scrollFill)" stroke="url(#scrollStroke)" stroke-width="6"></path>
                        <path d="M59 34c0-8 6-14 14-14h16c8 0 14 6 14 14v18H59V34Z" fill="#f7d596" stroke="#7c4d24" stroke-width="6"></path>
                        <path d="M45 58c0-10 8-18 18-18s18 8 18 18-8 18-18 18-18-8-18-18Z" fill="#f4c87a" stroke="#7c4d24" stroke-width="6"></path>
                        <path d="M115 112c0-15 12-27 27-27s27 12 27 27-12 27-27 27-27-12-27-27Z" fill="#f4c87a" stroke="#7c4d24" stroke-width="6"></path>
                        <path d="M73 61h39M73 82h27M73 103h22" stroke="#8e6130" stroke-width="6" stroke-linecap="round"></path>
                        <path d="m135 103 10 8 17-16" stroke="#7bafd4" stroke-width="8" stroke-linecap="round" stroke-linejoin="round"></path>
                      </svg>
                    </div>
                    <img
                      class="resource-card__character resource-card__character--progression"
                      src={`${base}assets/starsavior/starsavior/tychara/972a42523cd7095228d9b0ac3eb35bfa97a1aca7.webp`}
                      alt=""
                      loading="lazy"
                      decoding="async"
                    />
                  </div>
                )}

                {card.art === "gear" && (
                  <div class="resource-card__gear-visual">
                    <div class="resource-card__glyph resource-card__glyph--gear">
                      <svg viewBox="0 0 200 180" fill="none">
                        <defs>
                          <linearGradient id="bladeFill" x1="33" y1="18" x2="113" y2="150" gradientUnits="userSpaceOnUse">
                            <stop stop-color="#fff4ff"></stop>
                            <stop offset="1" stop-color="#c48cff"></stop>
                          </linearGradient>
                          <linearGradient id="shieldFill" x1="105" y1="42" x2="172" y2="160" gradientUnits="userSpaceOnUse">
                            <stop stop-color="#ffe3a9"></stop>
                            <stop offset="1" stop-color="#d9984f"></stop>
                          </linearGradient>
                        </defs>
                        <path d="m57 150 33-117 16 16-18 74 29 29-16 16-29-29-15 11Z" fill="url(#bladeFill)" stroke="#b8923e" stroke-width="7" stroke-linejoin="round"></path>
                        <path d="m44 154 17-12 11 11-13 17-15-16Z" fill="#d9984f" stroke="#7d4c20" stroke-width="7" stroke-linejoin="round"></path>
                        <path d="M110 47 147 29l36 18v37c0 33-21 61-54 71-33-10-54-38-54-71V47Z" fill="url(#shieldFill)" stroke="#7d4c20" stroke-width="7" stroke-linejoin="round"></path>
                        <circle cx="129" cy="84" r="17" fill="#7bafd4" stroke="#f4d18f" stroke-width="7"></circle>
                      </svg>
                    </div>
                    <img
                      class="resource-card__character resource-card__character--gear"
                      src={`${base}assets/starsavior/starsavior/tychara/ef88ab29622d77227a30b33cfdbf430055a51274.webp`}
                      alt=""
                      loading="lazy"
                      decoding="async"
                    />
                  </div>
                )}

                {card.art === "builds" && (
                  <div class="resource-card__builds-visual">
                    <img
                      class="resource-card__character resource-card__character--builds"
                      src={card.characterSrc}
                      alt=""
                      loading="lazy"
                      decoding="async"
                    />
                    <div class="resource-card__builds-badges">
                      {card.badges?.map((badge) => <span>{badge}</span>)}
                    </div>
                  </div>
                )}
              </div>
            </a>
          ))}

          <div class="shortcut-strip">
            <p class="shortcut-strip__label">Quick Jumps</p>
            <div class="shortcut-strip__links">
              {quickLinks.map((link) => (
                <a href={link.href}>{link.label}</a>
              ))}
            </div>
          </div>
        </div>

        <aside class="landing-rail">
          {railLinks.map((item) => (
            <a
              class="rail-card"
              href={item.href}
              target={item.external ? "_blank" : undefined}
              rel={item.external ? "noreferrer" : undefined}
            >
              <span class={`rail-card__icon rail-card__icon--${item.icon}`} aria-hidden="true">
                {item.icon === "community" && (
                  <svg viewBox="0 0 48 48" fill="none">
                    <circle cx="16" cy="18" r="6" fill="currentColor"></circle>
                    <circle cx="32" cy="16" r="5" fill="currentColor"></circle>
                    <circle cx="26" cy="28" r="7" fill="currentColor"></circle>
                    <path d="M9 36c0-4 4-7 9-7s9 3 9 7v2H9v-2ZM24 39v-2c0-5 4-8 10-8s10 3 10 8v2H24Z" fill="currentColor"></path>
                  </svg>
                )}
                {item.icon === "docs" && (
                  <svg viewBox="0 0 48 48" fill="none">
                    <path d="M14 7h15l9 9v23a2 2 0 0 1-2 2H14a2 2 0 0 1-2-2V9a2 2 0 0 1 2-2Z" stroke="currentColor" stroke-width="4" stroke-linejoin="round"></path>
                    <path d="M29 7v10h10" stroke="currentColor" stroke-width="4" stroke-linejoin="round"></path>
                    <path d="M18 25h12M18 31h12" stroke="currentColor" stroke-width="4" stroke-linecap="round"></path>
                  </svg>
                )}
                {item.icon === "spark" && (
                  <svg viewBox="0 0 48 48" fill="none">
                    <path d="m24 6 4.5 12 12 4.5-12 4.5L24 39l-4.5-12L7.5 22.5l12-4.5L24 6Z" fill="currentColor"></path>
                  </svg>
                )}
              </span>

              <div class="rail-card__copy">
                <strong>{item.title}</strong>
                <p>{item.description}</p>
                <span class="rail-card__cta">{item.cta} <span aria-hidden="true">→</span></span>
                {item.note && <small>{item.note}</small>}
              </div>
            </a>
          ))}

          <div class="landing-rail__sigil" aria-hidden="true">
            <svg viewBox="0 0 120 120" fill="none">
              <path d="m60 18 10 22 22 10-22 10-10 22-10-22-22-10 22-10 10-22Z" fill="url(#sigilFill)"></path>
              <defs>
                <linearGradient id="sigilFill" x1="24" y1="18" x2="94" y2="84" gradientUnits="userSpaceOnUse">
                  <stop stop-color="#f5eed6"></stop>
                  <stop offset="1" stop-color="#7bafd4"></stop>
                </linearGradient>
              </defs>
            </svg>
          </div>
        </aside>
      </div>
    </section>
  </div>

  <style>
    :global(html[data-game="starsavior"]) {
      --accent: #c8a04e;
      --accent-strong: #f5eed6;
      --accent-ice: #7bafd4;
    }

    :global(html[data-game="starsavior"] body) {
      background:
        radial-gradient(circle at 78% 6%, rgba(200, 160, 78, 0.16), transparent 18%),
        radial-gradient(circle at 16% 14%, rgba(123, 175, 212, 0.16), transparent 20%),
        linear-gradient(180deg, #08111f 0%, #0a1628 42%, #08111c 100%);
    }

    :global(html[data-game="starsavior"] .site-header) {
      background: linear-gradient(180deg, rgba(11, 18, 36, 0.92), rgba(8, 14, 28, 0.74));
      border-bottom-color: rgba(200, 160, 78, 0.16);
      box-shadow: 0 18px 44px rgba(3, 7, 17, 0.24);
    }

    :global(html[data-game="starsavior"] .sub-nav-bar) {
      display: none;
    }

    :global(html[data-game="starsavior"] .primary-nav__link:hover),
    :global(html[data-game="starsavior"] .primary-nav__link.active) {
      background: rgba(123, 175, 212, 0.14);
      border-color: rgba(200, 160, 78, 0.16);
    }

    :global(html[data-game="starsavior"] .header-icon-link),
    :global(html[data-game="starsavior"] .theme-toggle) {
      background: rgba(25, 34, 61, 0.76);
      border-color: rgba(200, 160, 78, 0.18);
    }

    .starsavior-landing {
      position: relative;
      padding: 0.9rem 0 4.5rem;
      overflow: clip;
      isolation: isolate;
    }

    .starsavior-landing__backdrop {
      position: absolute;
      inset: 0;
      pointer-events: none;
      z-index: -1;
    }

    .starsavior-landing__orb {
      position: absolute;
      border-radius: 999px;
      filter: blur(88px);
      opacity: 0.6;
    }

    .starsavior-landing__orb--violet {
      top: 6.5rem;
      right: 4rem;
      width: 18rem;
      height: 18rem;
      background: rgba(200, 160, 78, 0.26);
    }

    .starsavior-landing__orb--blue {
      top: 20rem;
      left: -4rem;
      width: 16rem;
      height: 16rem;
      background: rgba(84, 162, 255, 0.18);
    }

    .starsavior-landing__orb--rose {
      bottom: 8rem;
      right: 24%;
      width: 14rem;
      height: 14rem;
      background: rgba(245, 238, 214, 0.12);
    }

    .starsavior-landing__hero-section {
      position: relative;
      z-index: 1;
    }

    .landing-banner {
      position: relative;
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(300px, 36%);
      align-items: stretch;
      min-height: 23rem;
      padding: clamp(1.35rem, 2.6vw, 2.35rem);
      border: 1px solid rgba(164, 188, 236, 0.14);
      border-radius: 34px;
      overflow: hidden;
      background-image:
        linear-gradient(96deg, rgba(5, 11, 23, 0.98) 0%, rgba(8, 14, 28, 0.94) 34%, rgba(18, 22, 42, 0.42) 100%),
        radial-gradient(circle at 82% 12%, rgba(200, 160, 78, 0.26), transparent 20%),
        radial-gradient(circle at 72% 0%, rgba(123, 175, 212, 0.22), transparent 24%),
        var(--banner-image);
      background-position: center, 82% 12%, 72% 0%, center;
      background-size: cover;
      box-shadow: 0 30px 70px rgba(2, 7, 16, 0.34);
    }

    .landing-banner::after {
      content: "";
      position: absolute;
      inset: auto 0 0;
      height: 40%;
      background: linear-gradient(180deg, transparent, rgba(4, 8, 16, 0.52));
      pointer-events: none;
    }

    .landing-banner__copy,
    .landing-banner__art {
      position: relative;
      z-index: 1;
    }

    .landing-banner__copy {
      display: grid;
      align-content: start;
      gap: 1rem;
      max-width: 38rem;
    }

    .landing-banner__eyebrow {
      margin: 0;
      font-size: 0.84rem;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: #f0ddb4;
    }

    .landing-banner__title {
      margin: 0;
      font-family: "Fraunces", Georgia, serif;
      font-size: clamp(3.2rem, 8vw, 5.3rem);
      line-height: 0.92;
      letter-spacing: -0.05em;
      text-shadow: 0 10px 32px rgba(0, 0, 0, 0.24);
    }

    .landing-banner__summary {
      margin: 0;
      max-width: 34rem;
      font-size: 1.04rem;
      line-height: 1.7;
      color: rgba(235, 241, 255, 0.78);
    }

    .landing-banner__actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.8rem;
    }

    .landing-button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.55rem;
      min-height: 48px;
      padding: 0.8rem 1.15rem;
      border-radius: 999px;
      border: 1px solid rgba(219, 175, 255, 0.14);
      background: linear-gradient(135deg, #b8923e, #d4ac5a);
      color: #fff9ec;
      font-weight: 700;
      box-shadow: 0 16px 34px rgba(200, 160, 78, 0.22);
      transition: transform 160ms ease, box-shadow 160ms ease, background 160ms ease;
    }

    .landing-button:hover {
      transform: translateY(-1px);
      box-shadow: 0 22px 40px rgba(200, 160, 78, 0.24);
    }

    .landing-button--ghost {
      background: rgba(14, 22, 42, 0.74);
      box-shadow: none;
    }

    .landing-banner__stats {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0.8rem;
      margin: 0;
      padding: 0;
      list-style: none;
      max-width: 34rem;
    }

    .landing-banner__stats li {
      padding: 0.95rem 1rem;
      border-radius: 22px;
      background: rgba(10, 17, 33, 0.58);
      border: 1px solid rgba(185, 206, 255, 0.12);
      backdrop-filter: blur(16px);
    }

    .landing-banner__stats strong {
      display: block;
      font-size: 1.5rem;
      font-weight: 700;
      color: #ffffff;
    }

    .landing-banner__stats span {
      display: block;
      margin-top: 0.2rem;
      font-size: 0.82rem;
      color: rgba(226, 236, 255, 0.7);
    }

    .landing-banner__citation {
      display: flex;
      flex-wrap: wrap;
      gap: 0.65rem 1rem;
      margin: 0;
      font-size: 0.82rem;
      color: rgba(219, 229, 249, 0.72);
    }

    .landing-banner__citation a {
      color: #b9dbef;
      text-decoration: underline;
      text-decoration-color: rgba(185, 219, 239, 0.28);
      text-underline-offset: 0.18rem;
    }

    .landing-banner__art {
      min-height: 20rem;
    }

    .landing-banner__beam {
      position: absolute;
      inset: 16% auto auto 24%;
      width: 14rem;
      height: 14rem;
      border-radius: 999px;
      background: radial-gradient(circle at center, rgba(212, 172, 90, 0.34), rgba(123, 175, 212, 0.18) 55%, transparent 70%);
      filter: blur(8px);
    }

    .landing-banner__character {
      position: absolute;
      bottom: -0.5rem;
      height: min(27rem, 90%);
      object-fit: contain;
      filter: drop-shadow(0 18px 30px rgba(3, 7, 17, 0.38));
      user-select: none;
    }

    .landing-banner__character--lead {
      right: 1.5rem;
      z-index: 2;
    }

    .landing-banner__character--support {
      right: 12rem;
      bottom: 1rem;
      height: min(23rem, 72%);
      opacity: 0.92;
    }

    .starsavior-landing__resources {
      margin-top: 1.25rem;
    }

    .landing-section-head {
      display: grid;
      gap: 0.45rem;
      margin-bottom: 1.05rem;
    }

    .landing-section-head__eyebrow {
      display: inline-flex;
      flex-wrap: wrap;
      gap: 0.55rem;
      margin: 0;
      font-size: 0.88rem;
      font-weight: 700;
      color: rgba(235, 240, 255, 0.78);
    }

    .landing-section-head__eyebrow span:first-child {
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: rgba(255, 255, 255, 0.88);
    }

    .landing-section-head__eyebrow span:last-child {
      color: rgba(185, 219, 239, 0.72);
    }

    .landing-section-head h2 {
      margin: 0;
      font-family: "Fraunces", Georgia, serif;
      font-size: clamp(1.55rem, 3.2vw, 2.15rem);
      line-height: 1.05;
