---
import GameLayout from "../../../layouts/GameLayout.astro";
import Hero from "../../../components/starsavior/Hero.astro";
import CitationBanner from "../../../components/starsavior/CitationBanner.astro";
import DraftBadge from "../../../components/shared/DraftBadge.astro";
import { guides } from "../../../data/epicseven/content";
import { getRelatedBuildsForGuide } from "../../../data/epicseven/relations";
import AncientInheritancePrimer from "../../../content/epicseven/guides/ancient-inheritance-primer.mdx";

const guideComponents = {
  "ancient-inheritance-primer": AncientInheritancePrimer,
};

export async function getStaticPaths() {
  return guides.map((guide) => ({
    params: { slug: guide.slug },
    props: { guide }
  }));
}

const { guide } = Astro.props;
const Content = guideComponents[guide.slug as keyof typeof guideComponents];
const relatedBuilds = getRelatedBuildsForGuide(guide.slug);
---

<GameLayout
  title={`${guide.title} | Epic Seven`}
  description={guide.summary}
  game="epicseven"
>
  <Hero
    title={guide.title}
    summary={guide.summary}
  />

  <section class="container stack">
    <DraftBadge status={guide.status} placement="inline" />

    <CitationBanner sourceTabs={guide.sourceTabs} updatedAt={guide.updatedAt} />

    <nav class="guide-toc" aria-label="Guide sections">
      {guide.sections.map((section) => (
        <a href={`#${section.id}`} class="guide-toc-link">{section.title}</a>
      ))}
    </nav>

    <div class="split-layout">
      <article class="panel prose" style="padding: 1.5rem;">
        <Content />
      </article>

      <aside class="aside-card">
        <h3>On this page</h3>
        <ul>
          {guide.sections.map((section) => (
            <li>
              <a href={`#${section.id}`}>{section.title}</a>
            </li>
          ))}
        </ul>
      </aside>
    </div>

    {relatedBuilds.length > 0 && (
      <div class="panel" style="padding: 1.4rem;">
        <div class="section-heading">
          <div>
            <p class="eyebrow">Related Builds</p>
            <h2>Suggested builds for this guide</h2>
          </div>
        </div>
        <div class="card-grid">
          {relatedBuilds.map((build) => (
            <a class="content-card" href={`/epicseven/builds/${build.slug}/`}>
              <h3>{build.name}</h3>
              <p>{build.role}</p>
            </a>
          ))}
        </div>
      </div>
    )}
  </section>
</GameLayout>
