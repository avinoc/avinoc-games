---
import DraftBadge from "../../components/shared/DraftBadge.astro";

interface ExampleEntry {
  slug: string;
  title: string;
  summary: string;
  status: "draft" | "published" | "needs-review";
}

const { entry } = Astro.props as { entry: ExampleEntry };
---

<DraftBadge status={entry.status}>
  <article class="{{SLUG}}-example-card">
    <h2>{entry.title}</h2>
    <p>{entry.summary}</p>
    <a href={`/${entry.slug}/`}>Open entry</a>
  </article>
</DraftBadge>

<style>
  .{{SLUG}}-example-card {
    display: grid;
    gap: 0.8rem;
    padding: 1.1rem;
    border-radius: 1.2rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(8, 14, 24, 0.84);
    box-shadow: 0 18px 36px rgba(0, 0, 0, 0.24);
  }

  .{{SLUG}}-example-card h2,
  .{{SLUG}}-example-card p {
    margin: 0;
  }

  .{{SLUG}}-example-card a {
    color: var(--accent, #7bafd4);
    font-weight: 700;
    text-decoration: none;
  }
</style>
