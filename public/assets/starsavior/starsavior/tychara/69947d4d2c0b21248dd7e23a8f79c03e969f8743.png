</style></head> <body>  <div class="main-content-wrapper">   <script>
  document.body.classList.add('site-navbar-layout');
  function setActiveLink() {
    const currentPath = window.location.pathname.replace(/^\/+|\/+$/g, '').toLowerCase() || 'index';
    document.querySelectorAll('.left-menu-nav .nav-link-item').forEach(link => {
      const href = link.getAttribute('href') || '';
      const linkPath = href.replace(/^\/+|\/+$/g, '').toLowerCase() || 'index';
      link.classList.toggle('active', linkPath === currentPath);
    });
  }
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', setActiveLink);
  else setActiveLink();
  window.addEventListener('popstate', setActiveLink);
