<!DOCTYPE html><html lang="en"> <head><script>
      const hasVideoAdFree = document.cookie.includes('tychara_ad_free=true');
      const hasSupporterAdFree = document.cookie.includes('tychara_supporter_ad_free=true');
      const isAdFree = hasVideoAdFree || hasSupporterAdFree;
      if (isAdFree) {
        // Hint for Ezoic ad restrictions: disable ads for this page view.
        const disableAdsMeta = document.createElement('meta');
        disableAdsMeta.name = 'disable_ads';
        disableAdsMeta.content = '1';
        document.head.appendChild(disableAdsMeta);

        // Ezoic standalone config (when available) to disable interstitial/vignette ads.
        window.ezstandalone = window.ezstandalone || {};
        window.ezstandalone.cmd = window.ezstandalone.cmd || [];
        window.ezstandalone.cmd.push(function () {
          window.ezstandalone.config({
            disableInterstitial: true,
            vignetteDesktop: false,
            vignetteMobile: false,
            vignetteTablet: false,
          });
        });

        document.documentElement.classList.add('ty-ad-free-mode');
        const stripGoogleVignette = () => {
          const hash = (window.location.hash || '').toLowerCase();
          if (hash.includes('google_vignette')) {
            history.replaceState(null, '', window.location.pathname + window.location.search);
          }
        };

        stripGoogleVignette();
        window.addEventListener('hashchange', stripGoogleVignette);
        window.addEventListener('pageshow', stripGoogleVignette);
        window.addEventListener('load', stripGoogleVignette);

        // Some ad scripts re-apply this hash shortly after load.
        let tries = 0;
        const maxTries = 40; // ~10s
        const timer = window.setInterval(() => {
          stripGoogleVignette();
          tries += 1;
          if (tries >= maxTries) window.clearInterval(timer);
        }, 250);
      }
    </script><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><meta name="generator" content="Astro v5.17.1"><title>Tychara - Gacha Guides, Tier Lists &amp; Builds</title><link href="/favicon.ico" rel="icon" type="image/x-icon"><meta name="description" content="Guides, tier lists, and builds for Star Savior, Star Sailors, Mongil: Star Dive, and more gacha games."><meta name="keywords" content="Gacha Guides, Tier Lists, Builds, Star Savior, Star Sailors, Mongil Star Dive, Game Guide"><!-- Google Analytics --><script async src="https://www.googletagmanager.com/gtag/js?id=G-HHK5DQPT94"></script> <script type="module">window.dataLayer=window.dataLayer||[];function a(){dataLayer.push(arguments)}a("js",new Date);a("config","G-HHK5DQPT94");</script><link rel="stylesheet" href="/css/components/header.css"><link rel="stylesheet" href="/css/components/slider.css"><link rel="stylesheet" href="/css/pages/home.css"><script type="module" src="/_astro/SanityVisualEditing.astro_astro_type_script_index_0_lang.DDUlSW2P.js"></script> <meta content="Tychara Team" name="author"> <style>/*! tailwindcss v4.2.1 | MIT License | https://tailwindcss.com *//*!
