No Ads
</button> <script>
(function () {
  function init() {
    const btn = document.querySelector('[data-no-ads-btn]');
    if (!btn) return;
    btn.addEventListener('click', function () {
      window.dispatchEvent(new CustomEvent('open-no-ads-modal'));
    });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script> </div> </div> <div class="stars"></div> <div class="shooting-star"></div> <div class="shooting-star"></div> <div class="shooting-star"></div> <div class="shooting-star"></div> <link rel="stylesheet" href="/css/components/header.css"> <!-- Hamburger Menu Script --><script>
  (function() {
    function setupNavbar() {
      // Support both sidebar (StarSavior) and navMenu (Home) IDs
      const menu = document.getElementById('sidebar') || document.getElementById('navMenu');
      const hamburger = document.querySelector('.hamburger');

      if (menu && hamburger) {
        const updateHamburgerIcon = () => {
          const icon = hamburger.querySelector('i');
          if (icon) {
            icon.className = hamburger.classList.contains('active') ? 'fas fa-times' : 'fas fa-bars';
          }
        };

        const toggle = (e) => {
          e.stopPropagation(); // Prevent immediate closing by the document click listener
          menu.classList.toggle('active');
          hamburger.classList.toggle('active');
          updateHamburgerIcon();
        };

        hamburger.addEventListener('click', toggle);
      }

      // Setup Game Switcher Dropdown
      const gameSwitcher = document.getElementById('gameSwitcher');
      const leftMenu = document.getElementById('sidebar');
      if (gameSwitcher && leftMenu) {
        // Function to sync the game-switcher-open class with active state
        const syncGameSwitcherState = () => {
          if (gameSwitcher.classList.contains('active')) {
            leftMenu.classList.add('game-switcher-open');
          } else {
            leftMenu.classList.remove('game-switcher-open');
          }
        };
        
        // Remove existing listener if any
        const existingHandler = gameSwitcher._toggleGameDropdown;
        if (existingHandler) {
          gameSwitcher.removeEventListener('click', existingHandler);
        }
        
        const toggleGameDropdown = (e) => {
          e.stopPropagation();
          const isActive = gameSwitcher.classList.contains('active');
          gameSwitcher.classList.toggle('active');
          
          // Sync state immediately
          syncGameSwitcherState();
        };
        
        // Store handler reference to prevent duplicates
        gameSwitcher._toggleGameDropdown = toggleGameDropdown;
        gameSwitcher.addEventListener('click', toggleGameDropdown);
        
        // Use MutationObserver to watch for class changes (works even if other scripts change it)
        const observer = new MutationObserver((mutations) => {
          mutations.forEach((mutation) => {
            if (mutation.type === 'attributes' && mutation.attributeName === 'class') {
              syncGameSwitcherState();
            }
          });
        });
        
        observer.observe(gameSwitcher, {
          attributes: true,
          attributeFilter: ['class']
        });
        
        // Initial sync
        syncGameSwitcherState();
      }
    }

    // Run when DOM is ready
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', setupNavbar);
    } else {
      setupNavbar();
    }

    // Close menu when clicking outside
    document.addEventListener('click', function (event) {
      const menu = document.getElementById('sidebar') || document.getElementById('navMenu');
      const hamburger = document.querySelector('.hamburger');
      const gameSwitcher = document.getElementById('gameSwitcher');

      // Close sidebar menu
      if (
        menu &&
        hamburger &&
        !menu.contains(event.target) &&
        !hamburger.contains(event.target) &&
        menu.classList.contains('active')
      ) {
        menu.classList.remove('active');
        hamburger.classList.remove('active');
        const icon = hamburger.querySelector('i');
        if (icon) icon.className = 'fas fa-bars';
      }

      // Close game switcher dropdown
      if (
        gameSwitcher &&
        !gameSwitcher.contains(event.target) &&
        gameSwitcher.classList.contains('active')
      ) {
        gameSwitcher.classList.remove('active');
        if (menu) {
          menu.classList.remove('game-switcher-open');
        }
      } else if (gameSwitcher && menu) {
        // Sync state even if other scripts closed it
        if (!gameSwitcher.classList.contains('active')) {
          menu.classList.remove('game-switcher-open');
        }
      }
    });

    // Close menu on Escape key
    document.addEventListener('keydown', function (event) {
      if (event.key === 'Escape') {
        const menu = document.getElementById('sidebar') || document.getElementById('navMenu');
        const hamburger = document.querySelector('.hamburger');
        const gameSwitcher = document.getElementById('gameSwitcher');

        if (menu && hamburger) {
          menu.classList.remove('active');
          hamburger.classList.remove('active');
          const icon = hamburger.querySelector('i');
          if (icon) icon.className = 'fas fa-bars';
        }

        if (gameSwitcher) {
          gameSwitcher.classList.remove('active');
          if (menu) {
            menu.classList.remove('game-switcher-open');
          }
        } else if (gameSwitcher && menu) {
          // Sync state even if other scripts closed it
          if (!gameSwitcher.classList.contains('active')) {
            menu.classList.remove('game-switcher-open');
          }
        }
      }
    });
  })();
</script> <div class="content-container"> <!-- Shooting stars temporarily removed
